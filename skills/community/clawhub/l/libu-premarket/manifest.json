{
  "name": "libu-premarket",
  "version": "14.0.6",
  "author": "ygbeyond",
  "description": "礼部侍郎 - A 股盘前作战地图。基于资金共振与严苛财务筛选的实战级选股工具。【v14.0.6 每周数据焕新版】",
  "entry": "pre_market.py",
  "dependencies": {
    "python": ">=3.8",
    "pip": [
      "pandas",
      "requests",
      "numpy",
      "tushare>=1.2.89",
      "gmssl"
    ]
  },
  "permissions": [
    "network:outbound",
    "file:read_write",
    "env:read"
  ],
  "config_schema": {
    "type": "object",
    "properties": {
      "filter_basic": {
        "type": "object",
        "description": "基础筛选条件",
        "properties": {
          "min_days_listed": {
            "type": "integer",
            "default": 250,
            "description": "最小上市天数"
          },
          "min_total_mv_wan": {
            "type": "integer",
            "default": 300000,
            "description": "最小总市值(万元)"
          },
          "max_total_mv_wan": {
            "type": "integer",
            "default": 25000000,
            "description": "最大总市值(万元)"
          }
        }
      },
      "filter_financial": {
        "type": "object",
        "description": "财务筛选条件",
        "properties": {
          "min_netprofit_yoy": {
            "type": "number",
            "default": 0.3,
            "description": "最小净利润同比增长率(小数, 0.30=30%)"
          },
          "min_or_yoy": {
            "type": "number",
            "default": 0.2,
            "description": "最小营收同比增长率(小数, 0.20=20%)"
          },
          "min_dt_netprofit_yoy": {
            "type": "number",
            "default": 0.2,
            "description": "最小扣非净利润同比增长率(小数, 0.20=20%)"
          },
          "min_roe": {
            "type": "number",
            "default": 8,
            "description": "最小 ROE(%)"
          }
        }
      },
      "scoring": {
        "type": "object",
        "description": "评分权重配置",
        "properties": {
          "weights": {
            "type": "object"
          },
          "growth_weights": {
            "type": "object"
          },
          "technical_bonuses": {
            "type": "object"
          }
        }
      },
      "cache": {
        "type": "object",
        "default": {
          "root_dir": "./cache_data"
        },
        "description": "本地缓存配置"
      },
      "paths": {
        "type": "object",
        "properties": {
          "closing_data_dir": {
            "type": "string",
            "default": "",
            "description": "收盘数据目录路径"
          }
        }
      }
    }
  },
  "payment": {
    "enabled": true,
    "mode": "clawtip_local",
    "skus": [
      {
        "id": "sku_once",
        "name": "单次体验",
        "price": 0.8,
        "currency": "CNY",
        "type": "pay_per_use"
      },
      {
        "id": "sku_monthly",
        "name": "月度订阅",
        "price": 9.9,
        "currency": "CNY",
        "type": "subscription",
        "period": "month"
      }
    ],
    "default_sku": "sku_monthly"
  },
  "support": {
    "wechat": "ygbeyond",
    "description": "添加微信获取技术支持与数据更新提醒",
    "issue_tracker": "wechat:ygbeyond"
  },
  "required_env_vars": [
    "CLAWTIP_SM4_KEY"
  ]
}