    "doctor": "node -e \"require('./index.js')\" 2>&1 | head -5",
    "postinstall": "bash scripts/init.sh"
  },
  "keywords": [
    "openclaw",
    "pipeline",
    "sevo",
    "ai-agent",
    "software-delivery",
    "vibe-coding",
