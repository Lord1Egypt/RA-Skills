{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--executable-path=/usr/bin/chromium",
        "--user-data-dir=/tmp/openclaw-chromium-profile",
        "--no-usage-statistics",
        "--no-performance-crux"
      ]
    }
  }
}
