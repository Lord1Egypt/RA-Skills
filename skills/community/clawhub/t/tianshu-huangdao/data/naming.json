  "five_grids": [
    {
      "name": "天格",
      "alias": "祖运",
      "description": "由姓氏决定，代表祖先留下的基础",
      "calculation": {
        "single_surname": "姓氏笔画 + 1",
        "compound_surname": "双字姓笔画相加（不加1）",
        "example": "单姓'李'=7+1=8；复姓'诸葛'=10+11=21"
      }
    },
    {
      "name": "人格",
      "alias": "主运",
      "description": "姓的最下一字与名字最上一字之和，是整个姓名的中心",
      "calculation": {
        "single_surname_single_given": "姓 + 名（单字名）",
        "single_surname_double_given": "姓 + 名字第一字",
        "compound_surname_single_given": "姓氏第二字 + 名",
        "compound_surname_double_given": "姓氏第二字 + 名字第一字",
        "example": "'刘江海'=15+7=22；'司马懿'=10+22=32"
      }
    },
    {
      "name": "地格",
      "alias": "前运",
      "description": "由名字决定，代表前半生命运",
      "calculation": {
        "single_given_name": "名字笔画 + 1",
        "double_given_name": "名字两字笔画相加",
        "example": "'周瑜'=13+1=14；'刘江海'=7+11=18"
      }
    },
    {
      "name": "总格",
      "alias": "后运",
      "description": "姓与名的总笔画数之和",
      "calculation": {
        "full": "姓氏总笔画 + 名字总笔画",
        "example": "'司马懿'=5+10+22=37；'刘江海'=15+7+11=33"
      }
    },
    {
      "name": "外格",
      "alias": "副运",
      "description": "姓的最后一字与名的最后一字的关系",
      "calculation": {
        "single_surname_single_given": "姓 + 名",
        "single_surname_double_given": "姓 + 名字最后一字",
        "compound_surname_single_given": "姓氏第一字 + 名",
        "compound_surname_double_given": "姓氏第一字 + 名字最后一字",
        "example": "'诸葛亮'=15+9=24；'司徒美嫦'=5+14=19"
      }
    }
  ],
