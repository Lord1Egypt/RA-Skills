# Tushare（可选，历史K线数据源）
# 安装：pip install tushare 或 pip install -e ".[tushare]"
TUSHARE_TOKEN=your_tushare_token_here
# 长桥 OpenAPI（可选，支持港股/美股）
LONGPORT_APP_KEY=your_longport_app_key_here
LONGPORT_APP_SECRET=your_longport_app_secret_here
LONGPORT_ACCESS_TOKEN=your_longport_access_token_here
MAX_SINGLE_POSITION=0.30
MAX_TOTAL_POSITION=0.80
MIN_MARKET_SCORE=4.0
VOL_MULTI=1.8
TARGET_RATE=0.06
STOP_LOSS_RATE=-0.04
HOLD_DAYS=5
BACKTEST_DAYS=250
COMMISSION_RATE=0.0003
STAMP_TAX_RATE=0.001
SLIPPAGE_RATE=0.001
CIRCUIT_BREAKER_DROP=-0.05
CORRELATION_THRESHOLD=0.7
POLL_INTERVAL=60
HTTP_TIMEOUT=10
MAX_RETRIES=3
DB_PATH=stock_skill.db
LOG_LEVEL=INFO
