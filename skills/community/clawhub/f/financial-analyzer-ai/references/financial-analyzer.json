  "financial_ratios": {
    "solvency": {
      "current_ratio": {
        "formula": "流动资产 / 流动负债",
        "healthy_range": "1.5 - 2.5",
        "warning_below": 1.0,
        "description": "衡量企业短期偿债能力"
      },
      "quick_ratio": {
        "formula": "(流动资产 - 存货) / 流动负债",
        "healthy_range": "1.0 - 1.5",
        "warning_below": 0.5,
        "description": "酸性测试比率，排除存货后的短期偿债能力"
      },
      "cash_ratio": {
        "formula": "(现金 + 现金等价物) / 流动负债",
        "healthy_range": "0.5 - 1.0",
        "warning_below": 0.2,
        "description": "最保守的流动性指标"
      },
      "debt_to_asset": {
        "formula": "总负债 / 总资产",
        "healthy_range": "0.3 - 0.6",
        "warning_above": 0.7,
        "description": "资产负债率，反映财务杠杆"
      },
      "debt_to_equity": {
        "formula": "总负债 / 所有者权益",
        "healthy_range": "0.5 - 1.5",
        "warning_above": 2.0,
        "description": "产权比率"
      },
      "interest_coverage": {
        "formula": "EBIT / 利息费用",
        "healthy_range": "> 3.0",
        "warning_below": 1.5,
        "description": "利息保障倍数"
      },
      "equity_multiplier": {
        "formula": "总资产 / 所有者权益",
        "healthy_range": "1.5 - 3.0",
        "description": "权益乘数，反映财务杠杆程度"
      }
    },
    "profitability": {
      "gross_margin": {
        "formula": "(营业收入 - 营业成本) / 营业收入",
        "description": "毛利率，反映产品定价能力和成本控制"
      },
      "operating_margin": {
        "formula": "营业利润 / 营业收入",
        "description": "营业利润率"
      },
      "net_margin": {
        "formula": "净利润 / 营业收入",
        "description": "净利率"
      },
      "ebitda_margin": {
        "formula": "EBITDA / 营业收入",
        "description": "EBITDA利润率，排除折旧摊销影响"
      },
      "roe": {
        "formula": "净利润 / 平均所有者权益",
        "healthy_range": "> 0.15",
        "description": "净资产收益率，杜邦分析核心指标"
      },
      "roa": {
        "formula": "净利润 / 平均总资产",
        "healthy_range": "> 0.05",
        "description": "总资产收益率"
      },
      "roic": {
        "formula": "NOPAT / (总资产 - 无息流动负债)",
        "healthy_range": "> WACC",
        "description": "投入资本回报率"
      },
      "eps": {
        "formula": "(净利润 - 优先股股利) / 流通在外普通股加权平均数",
        "description": "每股收益"
      }
    },
    "efficiency": {
      "inventory_turnover": {
        "formula": "营业成本 / 平均存货",
        "description": "存货周转率"
      },
      "days_inventory_outstanding": {
        "formula": "365 / 存货周转率",
        "description": "存货周转天数"
      },
      "receivables_turnover": {
        "formula": "营业收入 / 平均应收账款",
        "description": "应收账款周转率"
      },
      "days_sales_outstanding": {
        "formula": "365 / 应收账款周转率",
        "description": "应收账款周转天数"
      },
      "payables_turnover": {
        "formula": "营业成本 / 平均应付账款",
        "description": "应付账款周转率"
      },
      "days_payable_outstanding": {
        "formula": "365 / 应付账款周转率",
        "description": "应付账款周转天数"
      },
      "cash_conversion_cycle": {
        "formula": "DIO + DSO - DPO",
        "description": "现金转换周期，越短越好"
      },
      "asset_turnover": {
        "formula": "营业收入 / 平均总资产",
        "description": "总资产周转率"
      },
      "fixed_asset_turnover": {
        "formula": "营业收入 / 平均固定资产",
        "description": "固定资产周转率"
      }
    },
    "growth": {
      "revenue_growth": {
        "formula": "(当期营业收入 - 上期营业收入) / 上期营业收入",
        "description": "营收增长率"
      },
      "net_income_growth": {
        "formula": "(当期净利润 - 上期净利润) / 上期净利润",
        "description": "净利润增长率"
      },
      "asset_growth": {
        "formula": "(期末总资产 - 期初总资产) / 期初总资产",
        "description": "总资产增长率"
      },
      "operating_cf_growth": {
        "formula": "(当期经营现金流 - 上期经营现金流) / 上期经营现金流",
        "description": "经营活动现金流增长率"
      },
      "sustainable_growth_rate": {
        "formula": "ROE × (1 - 股利支付率)",
        "description": "可持续增长率"
      }
    },
    "cashflow": {
      "ocf_to_revenue": {
        "formula": "经营活动现金流 / 营业收入",
        "description": "收入现金含量"
      },
      "free_cashflow": {
        "formula": "经营活动现金流 - 资本支出",
        "description": "自由现金流"
      },
      "fcf_to_net_income": {
        "formula": "自由现金流 / 净利润",
        "description": "利润现金保障倍数"
      },
      "ocf_to_debt": {
        "formula": "经营活动现金流 / 总负债",
        "description": "现金流偿债能力"
      }
    }
  },
