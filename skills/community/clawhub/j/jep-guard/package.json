{
  "name": "@hjs-foundation/jep-guard",
  "version": "2.0.4",
  "description": "JEP Guard v2.0.4 — Causal Operating System for OpenClaw Skills. Security-hardened: zero auto-execution, zero shell commands during install, explicit consent for all privileged operations.",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "bin": {
    "jep-guard": "bin/jep-guard"
  },
  "files": [
    "dist/",
    "bin/",
    "scripts/",
    "schemas/",
    "skill.yaml",
    "openclaw.hooks.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x bin/jep-guard",
    "start": "node dist/daemon/server.js",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/post-install.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.0",
    "fast-json-stable-stringify": "^2.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "tar": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "keywords": [
    "jep",
    "guard",
    "causal-gate",
    "skill-os",
    "audit",
    "openclaw",
    "aegis",
    "agent",
    "accountability",
    "security"
  ],
  "license": "MIT-0",
  "repository": "https://github.com/hjs-foundation/jep-guard",
  "homepage": "https://clawhub.ai/hjs-foundation/jep-guard",
  "bugs": "https://github.com/hjs-foundation/jep-guard/issues"
}