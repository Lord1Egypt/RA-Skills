  "version": "1.13.1",
  "description": "SEVO — Automated software delivery pipeline for AI agents (Specify → Execute → Verify → Operate)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "sevo": "./bin/sevo.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
