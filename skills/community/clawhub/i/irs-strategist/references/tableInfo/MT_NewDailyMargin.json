    {
        "columnOrderId": 9,
        "columnName": "DepositRatio",
        "columnChiName": "保证金比例(%)",
        "columnType": "decimal(18,10)",
        "isNullable": 1,
        "remark": "保证金比例（DepositRatio）：发布机构是中信证券、海通证券、广发证券、上交所、深交所，取公布值；发布机构是光大证券：融资保证金比例=初始保证金比例+(1-融资买入证券折算率)融券保证金比例=初始保证金比例+(1-融券卖出证券折算率)+融券保证金比例上浮部分；发布机构是国信证券：融资保证金比例=1+国信公布的基准保证金比例-标的证券折算率融券保证金比例=(1+国信公布的基准保证金比例-标的证券折算率）×调整倍数；发布机构是国泰君安：融资保证金比例=交易所公布的最低融资保证金比例+（1-标的证券折算率）",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "99.99",
        "remarkNo": "注4"
    },
