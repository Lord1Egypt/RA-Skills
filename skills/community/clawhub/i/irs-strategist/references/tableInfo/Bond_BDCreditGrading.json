    {
        "columnOrderId": 10,
        "columnName": "CRCode",
        "columnChiName": "信用级别代码",
        "columnType": "int",
        "isNullable": 0,
        "remark": "信用级别代码（CRCode）：与“系统常量表”中的“常量代码（DM）”关联，“LB”根据“评级类别（CRTypeCode）”来确定。\n当评级类别（CRTypeCode） = 1 时，令“LB = 1407”，得到证券的短期信用评级描述：\n99- A-1+，95- A-1，90- A-1-，85- A-2，75- A-3，65- B，55- C，45- D；\n       当评级类别（CRTypeCode） = 2 时，令“LB IN (1372,1704)”，得到证券的长期信用评级描述 (LB=1372)：1000- AAA+，\n999- AAA，990- AAA-，980- AA+，970- AA，960- AA-，950- A+，940- A，930- A-，899- BBB+，895- BBB，891- BBB-，880-BB+，870- BB，860-BB-，850-B+，840- B，830- B-，799- CCC，770- CC，760- C，740- D;   (LB = 1704 AND (DM < 200 OR DM IN (401,405,407)))：\n101- Aaa，102-Aa1，103- Aa2，104- Aa3 等。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "100.0",
        "remarkNo": "注5"
    },
