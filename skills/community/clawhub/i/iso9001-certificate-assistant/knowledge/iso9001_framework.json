{
    "standard": "ISO 9001:2015",
    "title": "Quality Management Systems - Requirements",
    "title_zh": "质量管理体系 - 要求",
    "clauses": {
        "4": {
            "title": "Context of the Organization",
            "title_zh": "组织环境",
            "subclauses": {
                "4.1": {
                    "title": "Understanding the organization and its context",
                    "title_zh": "理解组织及其环境",
                    "required_documents": ["组织环境分析报告"]
                },
                "4.2": {
                    "title": "Understanding the needs and expectations of interested parties",
                    "title_zh": "理解相关方的需求和期望",
                    "required_documents": ["相关方需求和期望清单"]
                },
                "4.3": {
                    "title": "Determining the scope of the quality management system",
                    "title_zh": "确定质量管理体系的范围",
                    "required_documents": ["质量手册"]
                },
                "4.4": {
                    "title": "Quality management system and its processes",
                    "title_zh": "质量管理体系及其过程",
                    "required_documents": ["过程清单", "过程相互作用图"]
                }
            }
        },
        "5": {
            "title": "Leadership",
            "title_zh": "领导作用",
            "subclauses": {
                "5.1": {
                    "title": "Leadership and commitment",
                    "title_zh": "领导作用和承诺",
                    "required_documents": ["管理承诺声明"]
                },
                "5.2": {
                    "title": "Policy",
                    "title_zh": "方针",
                    "required_documents": ["质量方针"]
                },
                "5.3": {
                    "title": "Organizational roles, responsibilities and authorities",
                    "title_zh": "组织的角色、职责和权限",
                    "required_documents": ["组织结构图", "职责分配表"]
                }
            }
        },
        "6": {
            "title": "Planning",
            "title_zh": "策划",
            "subclauses": {
                "6.1": {
                    "title": "Actions to address risks and opportunities",
                    "title_zh": "应对风险和机遇的措施",
                    "required_documents": ["风险和机遇识别与评价程序"]
                },
                "6.2": {
                    "title": "Quality objectives and planning to achieve them",
                    "title_zh": "质量目标及其实现的策划",
                    "required_documents": ["质量目标管理程序"]
                },
                "6.3": {
                    "title": "Planning of changes",
                    "title_zh": "变更的策划",
                    "required_documents": ["变更管理程序"]
                }
            }
        },
        "7": {
            "title": "Support",
            "title_zh": "支持",
            "subclauses": {
                "7.1": {
                    "title": "Resources",
                    "title_zh": "资源",
