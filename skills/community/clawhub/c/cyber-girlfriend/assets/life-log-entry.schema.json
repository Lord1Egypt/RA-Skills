{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/cyber-girlfriend.life-log-entry.schema.json",
  "title": "Cyber Girlfriend Life Log Entry",
  "type": "object",
  "required": [
    "ts",
    "mode",
    "date",
    "life_claims",
    "source_day"
  ],
  "properties": {
    "ts": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "minLength": 1 },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "life_claims": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_day": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
