# 测试案例集

## 案例1：高置信度自动校正
```json
{
  "case_id": "TC001",
  "description": "命宫空宫，±1时辰后置信度显著提升",
  "input": {
    "trace_id": "test-001",
    "skill_name": "ziwei",
    "execution_time": 1.2,
    "timestamp": "2024-01-01T12:00:00Z",
    "status": "SUCCESS",
    "confidence": 0.35,
    "data": {
      "birth_info": {
        "gender": "M",
        "birth_dt": "1993-04-01T14:00:00+08:00",
        "location": "北京"
      },
      "chart_data": {"simulated": true}
    },
    "verification_points": [
      {
        "field": "命宫主星",
        "description": "命宫为空宫，主星落陷",
        "impact": "high",
        "suggestions": ["考虑生时校正", "检查出生时间"],
        "related_fields": ["命宫", "身宫"]
      },
      {
        "field": "迁移宫",
        "description": "迁移宫化忌",
        "impact": "medium",
        "suggestions": ["调整出行方向"],
        "related_fields": ["迁移宫"]
      }
    ],
    "errors": [],
    "warnings": [],
    "metadata": {"cache_key": "test:19930401M"}
  },
  "expected": {
    "status": "CALIBRATION_DONE",
    "confidence_min": 0.7,
    "verification_points_high_impact_max": 0,
    "shift_hours_in": [-2, 2]
  }
}
```

