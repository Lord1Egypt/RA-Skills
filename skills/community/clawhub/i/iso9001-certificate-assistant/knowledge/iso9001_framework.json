                "8.2": {
                    "title": "Requirements for products and services",
                    "title_zh": "产品和服务的要求",
                    "required_documents": ["市场和客户需求管理程序"]
                },
                "8.3": {
                    "title": "Design and development of products and services",
                    "title_zh": "产品和服务的设计和开发",
                    "required_documents": ["设计和开发控制程序"]
                },
                "8.4": {
                    "title": "Control of externally provided processes, products and services",
                    "title_zh": "外部提供的过程、产品和服务的控制",
                    "required_documents": ["采购控制程序", "供应商管理程序"]
                },
                "8.5": {
                    "title": "Production and service provision",
                    "title_zh": "生产和服务提供",
                    "required_documents": ["服务提供控制程序", "服务提供规范"]
                },
                "8.6": {
                    "title": "Release of products and services",
                    "title_zh": "产品和服务的放行",
                    "required_documents": ["产品和服务放行程序"]
                },
                "8.7": {
                    "title": "Control of nonconforming outputs",
                    "title_zh": "不合格输出的控制",
                    "required_documents": ["不合格和纠正措施控制程序"]
                }
            }
        },
        "9": {
            "title": "Performance Evaluation",
            "title_zh": "绩效评价",
            "subclauses": {
                "9.1": {
                    "title": "Monitoring, measurement, analysis and evaluation",
                    "title_zh": "监视、测量、分析和评价",
                    "subclauses": {
                        "9.1.1": {
                            "title": "General",
                            "title_zh": "总则",
                            "required_documents": ["监视和测量控制程序"]
                        },
                        "9.1.2": {
                            "title": "Customer satisfaction",
                            "title_zh": "客户满意",
                            "required_documents": ["客户满意度测量程序"]
                        },
                        "9.1.3": {
                            "title": "Analysis and evaluation",
                            "title_zh": "分析和评价",
                            "required_documents": ["数据分析程序"]
                        }
                    }
                },
                "9.2": {
                    "title": "Internal audit",
                    "title_zh": "内部审核",
                    "required_documents": ["内部审核程序"]
                },
                "9.3": {
                    "title": "Management review",
                    "title_zh": "管理评审",
                    "required_documents": ["管理评审程序"]
                }
            }
        },
        "10": {
            "title": "Improvement",
            "title_zh": "改进",
            "subclauses": {
                "10.1": {
                    "title": "General",
                    "title_zh": "总则",
                    "required_documents": ["改进管理程序"]
                },
                "10.2": {
                    "title": "Nonconformity and corrective action",
                    "title_zh": "不合格和纠正措施",
                    "required_documents": ["不合格和纠正措施控制程序"]
                },
                "10.3": {
                    "title": "Continual improvement",
                    "title_zh": "持续改进",
                    "required_documents": ["持续改进程序"]
                }
            }
        }
