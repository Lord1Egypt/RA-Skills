      {"function": "new Function()", "risk": "严重", "cwe": "CWE-95", "reason": "从字符串创建函数相当于 eval", "alternative": "避免动态创建函数"},
      {"function": "setTimeout/setInterval (字符串)", "risk": "严重", "cwe": "CWE-95", "reason": "传入字符串参数相当于 eval", "alternative": "传入函数引用"},
      {"function": "child_process.exec()", "risk": "严重", "cwe": "CWE-78", "reason": "通过 Shell 执行命令", "alternative": "child_process.execFile() 或 spawn()"},
      {"function": "element.innerHTML", "risk": "高", "cwe": "CWE-79", "reason": "直接设置 HTML 内容", "alternative": "textContent 或 DOMPurify"},
      {"function": "document.write()", "risk": "高", "cwe": "CWE-79", "reason": "直接写入 HTML", "alternative": "DOM API"},
      {"function": "dangerouslySetInnerHTML", "risk": "高", "cwe": "CWE-79", "reason": "React 中直接设置 HTML", "alternative": "DOMPurify 消毒后再使用"},
      {"function": "Math.random()", "risk": "中", "cwe": "CWE-330", "reason": "非密码学安全", "alternative": "crypto.randomBytes() 或 crypto.getRandomValues()"},
