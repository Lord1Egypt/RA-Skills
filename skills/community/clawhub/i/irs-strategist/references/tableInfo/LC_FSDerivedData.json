    {
        "columnOrderId": 10,
        "columnName": "InterestFreeCLiabilities",
        "columnChiName": "无息流动负债",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "无息流动负债（InterestFreeCLiabilities）=应付帐款及应付票据+预收款项+合同负债+应付职工薪酬+应交税费+其他应付款(含利息和股利)+预提费用+递延收益.流动负债+其他流动负债+衍生金融负债。其中：其他应付款(含利息和股利)包括：应付股利、应付利息、其他应付款；金融类企业不计算。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "92.87",
        "remarkNo": "注5"
    },
    {
        "columnOrderId": 11,
        "columnName": "InterestFreeNonCL",
        "columnChiName": "无息非流动负债",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "无息非流动负债（InterestFreeNonCL）=非流动负债合计-长期借款-应付债券-租赁负债；金融类企业不计算。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "92.87",
        "remarkNo": "注6"
    },
    {
        "columnOrderId": 12,
        "columnName": "InterestBearDebt",
        "columnChiName": "带息债务",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "带息债务（InterestBearDebt）:非金融类企业计算公式=负债合计－无息流动负债－无息非流动负债；“无息流动负债”计算方法见InterestFreeCLiability[无息流动负债]，“无息非流动负债”见InterestFreeNonCL[无息非流动负债]；\n金融类企业计算公式=负债合计-卖出回购金融资产款-代理买卖证券款-代理承销证券款-应付职工薪酬-长期应付职工薪酬-应付款项-应交税费-应付利息-合同负债-划分为持有待售的负债-代理业务负债递延所得税负债-其他负债-衍生金融负债。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "97.97",
        "remarkNo": "注7"
    },
    {
        "columnOrderId": 13,
        "columnName": "NetDebt",
        "columnChiName": "净债务",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "净债务（NetDebt）=带息债务－货币资金；“带息债务”计算方法见InterestBearDebt[带息债务]；金融类企业不计算。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "92.87",
        "remarkNo": "注8"
    },
    {
        "columnOrderId": 14,
        "columnName": "TotalPaidinCapital",
        "columnChiName": "全部投入资本",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "全部投入资本（TotalPaidinCapital）=股东权益合计+带息债务；“带息债务”计算方法见InterestBearDebt[带息债务]；金融类企业不计算。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "92.87",
        "remarkNo": "注9"
    },
    {
