  "counter_strategies": {
    "product_attack": {
      "detection": "Competitor launches feature directly competing with your core product",
      "severity": "CRITICAL",
      "response_catalog": [
        "Accelerate roadmap for matching feature",
        "Highlight existing differentiators in marketing",
        "Launch complementary feature to neutralize",
        "Acquire technology/talent in adjacent space",
        "Expand to new vertical they cannot address"
      ]
    },
    "price_war": {
      "detection": "Competitor lowers prices by 30%+ or introduces aggressive free tier",
      "severity": "HIGH",
      "response_catalog": [
        "Emphasize premium value/ROI over price",
        "Launch value tier without devaluing premium",
        "Bundle with partner products for perceived savings",
        "Introduce usage-based pricing flexibility",
        "Ignore if attacking non-core segment"
      ]
    },
    "talent_raid": {
      "detection": "Competitor aggressively recruits from your team",
      "severity": "HIGH",
      "response_catalog": [
        "Review compensation benchmarks immediately",
        "Accelerate promotion cycles for at-risk roles",
        "Create retention bonuses tied to key milestones",
        "File legal review for non-compete/NDA violations",
        "Counter-offer with equity refresh grants"
      ]
    },
    "marketing_blitz": {
      "detection": "Competitor launches major brand campaign targeting your audience",
      "severity": "MEDIUM",
      "response_catalog": [
        "Amplify customer success stories and case studies",
        "Launch targeted comparison content (factual)",
        "Increase retargeting budget for existing leads",
        "Partner with industry analysts for positive coverage",
        "Launch product improvements to change narrative"
      ]
    }
  },
  "competitive_frameworks": {
    "swot": "Strengths, Weaknesses, Opportunities, Threats - Best for single competitor deep-dive analysis",
    "porters_five": "Supplier Power, Buyer Power, Competitive Rivalry, Threat of New Entry, Threat of Substitution - Best for industry attractiveness assessment",
    "blue_ocean": "Eliminate, Reduce, Raise, Create - Best for differentiation strategy and finding uncontested market space",
    "bcg_matrix": "Stars, Cash Cows, Question Marks, Dogs - Best for product portfolio management and resource allocation"
  },
  "historical_competitive_moves": {
    "openai_vs_google": {
      "timeline": [
        {
          "date": "2022-11",
          "event": "ChatGPT launch",
          "google_response": "Internal Code Red declared",
          "outcome": "Accelerated Gemini development by 12 months"
        },
        {
          "date": "2023-02",
          "event": "Microsoft Bing ChatGPT integration",
          "google_response": "Bard launch (rushed, stumbled on demo)",
          "outcome": "Google stock -8% on Bard demo error"
        },
        {
          "date": "2023-12",
          "event": "Gemini Ultra launch",
          "openai_response": "GPT-4 Turbo price cut 50%",
          "outcome": "AI API pricing war begins"
        },
        {
          "date": "2024-05",
          "event": "GPT-4o multimodal launch",
          "google_response": "Gemini 1.5 Flash (lower cost)",
          "outcome": "Multimodal becomes table stakes"
        },
        {
          "date": "2025-2026",
          "event": "Agentic AI race",
          "google_response": "Project Mariner (deep browser integration)",
          "openai_response": "Operator (autonomous desktop agent)",
          "outcome": "Battle shifts from models to autonomous agents"
        }
      ],
      "key_lesson": "Fast follower strategy works with distribution advantage (Google:Search/Android, Microsoft:Office/Windows)"
    },
    "tiktok_shop_vs_amazon": {
      "timeline": [
        {
          "date": "2023-09",
          "event": "TikTok Shop US launch",
          "amazon_response": "Amazon Inspire (shoppable feed)",
          "outcome": "Inspire failed to gain traction"
        },
        {
          "date": "2024-03",
          "event": "TikTok Shop $1B GMV month",
          "amazon_response": "Haul (Temu-competitive discount store)",
          "outcome": "Haul cannibalized Amazon's low-ASP sales"
        },
        {
          "date": "2024-11",
          "event": "TikTok Shop Black Friday ($2B GMV)",
          "amazon_response": "Rufus AI shopping assistant expansion",
          "outcome": "AI assistant differentiation vs social commerce"
        }
      ],
      "key_lesson": "Social commerce threats require social-native responses, not bolt-on features"
    },
    "cloudflare_vs_aws": {
      "timeline": [
        {
          "date": "2021",
          "event": "R2 storage launch (no egress fees)",
          "aws_response": "Price cut on S3 egress (limited scope)",
          "outcome": "Cloudflare gained significant SMB market share"
        },
        {
          "date": "2023",
          "event": "Workers AI (edge inference)",
          "aws_response": "Lambda@Edge ML upgrade",
          "outcome": "Edge AI becomes competitive differentiator"
        }
      ],
      "key_lesson": "Attack the incumbent's business model weakness rather than competing on feature parity"
    }
