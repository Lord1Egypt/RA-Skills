                        "7.1.1": {
                            "title": "General",
                            "title_zh": "总则",
                            "required_documents": ["资源提供和管理程序"]
                        },
                        "7.1.2": {
                            "title": "People",
                            "title_zh": "人员",
                            "required_documents": ["人力资源控制程序"]
                        },
                        "7.1.3": {
                            "title": "Infrastructure",
                            "title_zh": "基础设施",
                            "required_documents": ["基础设施控制程序"]
