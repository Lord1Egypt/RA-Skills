        "font-weight": "600",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center"
      },
      "html": "<div data-field=\"cell-1-2\"><div style=\"font-size:18px;margin-bottom:8px;\">绿色-纯文字</div><div style=\"font-size:12px;opacity:0.8;\">Row1 Col2</div></div>"
