{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldloops.dev/schemas/openclaw-signals.schema.json",
  "title": "OpenClaw Signals Input",
  "type": "object",
  "required": ["signals"],
  "additionalProperties": false,
  "properties": {
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "text"],
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string",
            "enum": ["slack", "gmail", "calendar", "github", "manual"]
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        }
      }
    }
  }
}
