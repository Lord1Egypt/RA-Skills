{
  "version": 1,
  "fact_types": {
    "preference": {
      "description": "User preferences and choices",
      "base_importance": 1.2,
      "patterns_en": [
        "(?i)\\bi\\s+prefer\\b",
        "(?i)\\bi\\s+like\\s+(?:to|using|working)\\b",
        "(?i)\\bi\\s+(?:always|usually|typically)\\s+(?:use|choose|go with)\\b",
        "(?i)\\bmy\\s+(?:favorite|preferred|go-to)\\b",
        "(?i)\\bi'd\\s+rather\\b"
      ],
      "patterns_ru": [
        "(?i)\\b(?:锌褉械写锌芯褔懈褌邪褞|薪褉邪胁懈褌褋褟|谢褞斜谢褞\\s+(?:懈褋锌芯谢褜蟹芯胁邪褌褜|褉邪斜芯褌邪褌褜))\\b",
        "(?i)\\b(?:芯斜褘褔薪芯|胁褋械谐写邪|泻邪泻 锌褉邪胁懈谢芯)\\s+(?:懈褋锌芯谢褜蟹褍褞|胁褘斜懈褉邪褞|写械谢邪褞)\\b",
        "(?i)\\b屑芯泄\\s+(?:谢褞斜懈屑褘泄|锌褉械写锌芯褔褌懈褌械谢褜薪褘泄)\\b",
        "(?i)\\b谢褍褔褕械\\s+(?:斜褍写褍|斜褘)\\b"
      ]
    },
    "decision": {
      "description": "Decisions made during conversation",
      "base_importance": 1.5,
      "patterns_en": [
        "(?i)\\b(?:let's|we'll|I'll)\\s+(?:go with|use|pick|choose|stick with)\\b",
        "(?i)\\b(?:decided|decision|settled on|agreed)\\b",
        "(?i)\\b(?:the plan is|going forward)\\b",
        "(?i)\\bwe\\s+(?:chose|picked|selected)\\b"
      ],
      "patterns_ru": [
        "(?i)\\b(?:褉械褕懈谢懈|褉械褕械薪懈械|写芯谐芯胁芯褉懈谢懈褋褜|芯锌褉械写械谢懈谢懈褋褜)\\b",
        "(?i)\\b(?:写邪胁邪泄|斜褍写械屑|胁褘斜懈褉邪械屑|斜械褉褢屑|芯褋褌邪薪芯胁懈屑褋褟 薪邪)\\b",
        "(?i)\\b(?:锌谢邪薪 褌邪泻芯泄|写邪谢褜褕械 斜褍写械屑)\\b",
        "(?i)\\b(?:胁褘斜褉邪谢懈|胁蟹褟谢懈|芯褋褌邪薪芯胁懈谢懈褋褜)\\b"
      ]
    },
    "identity": {
      "description": "Personal/professional identity facts",
      "base_importance": 1.3,
      "patterns_en": [
        "(?i)\\bi\\s+(?:am|work as|work at|work for|live in|moved to)\\b",
        "(?i)\\bmy\\s+(?:name|job|role|title|company|team|city)\\b",
        "(?i)\\bi'm\\s+(?:a|an|the)\\s+\\w+(?:er|or|ist|ant|ent)\\b",
        "(?i)\\bi\\s+(?:speak|know|study)\\s+\\w+(?:ish|ese|ian|ch)\\b"
      ],
      "patterns_ru": [
        "(?i)\\b褟\\s+(?:褉邪斜芯褌邪褞|卸懈胁褍|锌械褉械械褏邪谢|褍褔褍褋褜)\\b",
        "(?i)\\b(?:屑械薪褟 蟹芯胁褍褌|屑芯械 懈屑褟|屑芯褟 写芯谢卸薪芯褋褌褜|屑芯褟 褉芯谢褜)\\b",
        "(?i)\\b褟\\s+(?:懈蟹|胁)\\s+\\w+",
        "(?i)\\b屑芯褟\\s+(?:泻芯屑锌邪薪懈褟|泻芯屑邪薪写邪|褉邪斜芯褌邪)\\b"
      ]
    },
    "task": {
      "description": "Active tasks and to-dos",
      "base_importance": 1.4,
      "patterns_en": [
        "(?i)\\b(?:need to|have to|must|should|TODO|to-do|task)\\b",
        "(?i)\\b(?:deadline|due|by\\s+(?:monday|tuesday|wednesday|thursday|friday|saturday|sunday|tomorrow|next))\\b",
        "(?i)\\bremind\\s+me\\s+to\\b",
        "(?i)\\b(?:working on|building|implementing|fixing)\\b"
      ],
      "patterns_ru": [
        "(?i)\\b(?:薪褍卸薪芯|薪邪写芯|薪械芯斜褏芯写懈屑芯|蟹邪写邪褔邪|褋写械谢邪褌褜)\\b",
        "(?i)\\b(?:写械写谢邪泄薪|褋褉芯泻|泻\\s+(?:锌芯薪械写械谢褜薪懈泻|胁褌芯褉薪懈泻|褋褉械写邪|褔械褌胁械褉谐|锌褟褌薪懈褑|褋褍斜斜芯褌|胁芯褋泻褉械褋械薪褜|蟹邪胁褌褉邪))\\b",
        "(?i)\\b(?:薪邪锌芯屑薪懈|薪械 蟹邪斜褘褌褜)\\b",
        "(?i)\\b(?:褉邪斜芯褌邪褞 薪邪写|写械谢邪褞|褋褌褉芯褞|褔懈薪褞|锌懈褕褍)\\b"
      ]
    },
    "guardrail": {
      "description": "Critical rules that must never be forgotten",
      "base_importance": 10.0,
      "patterns_en": [
        "(?i)\\bnever\\s+\\w+\\b",
        "(?i)\\balways\\s+\\w+\\b(?!.*(?:use|prefer|like))",
        "(?i)\\b(?:must\\s+(?:not|never|always)|critical|rule|guardrail)\\b",
        "(?i)\\bdon'?t\\s+(?:ever|you\\s+dare)\\b",
        "(?i)\\b(?:remember\\s+this|never\\s+forget|this\\s+is\\s+critical)\\b",
        "(?i)\\b(?:safety|security|permission|approval)\\s+(?:rule|requirement|gate)\\b",
        "(?i)\\bwithout\\s+(?:my|explicit|user)\\s+(?:approval|permission|confirmation)\\b"
      ],
      "patterns_ru": [
        "(?i)\\b薪懈泻芯谐写邪\\s+(?:薪械\\s+)?\\w+",
        "(?i)\\b胁褋械谐写邪\\s+\\w+\\b(?!.*(?:懈褋锌芯谢褜蟹褍褞|锌褉械写锌芯褔懈褌邪褞|薪褉邪胁懈褌褋褟))",
        "(?i)\\b(?:芯斜褟蟹邪褌械谢褜薪芯|泻褉懈褌懈褔薪芯|胁邪卸薪芯|锌褉邪胁懈谢芯)\\b",
        "(?i)\\b(?:蟹邪锌芯屑薪懈\\s+褝褌芯|薪懈泻芯谐写邪\\s+薪械\\s+蟹邪斜褘胁邪泄|褝褌芯\\s+泻褉懈褌懈褔薪芯)\\b",
        "(?i)\\b(?:斜械蟹芯锌邪褋薪芯褋褌褜|褉邪蟹褉械褕械薪懈械|芯写芯斜褉械薪懈械)\\b",
        "(?i)\\b斜械蟹\\s+(?:屑芯械谐芯|褟胁薪芯谐芯)\\s+(?:芯写芯斜褉械薪懈褟|褉邪蟹褉械褕械薪懈褟|锌芯写褌胁械褉卸写械薪懈褟)\\b"
      ]
    },
    "contact": {
      "description": "People, contacts, relationships",
      "base_importance": 1.1,
      "patterns_en": [
        "(?i)\\bmy\\s+(?:boss|manager|colleague|friend|partner|wife|husband|client)\\b",
        "(?i)\\b(?:report to|work with|collaborate with|meeting with)\\b\\s+[A-Z]"
      ],
      "patterns_ru": [
        "(?i)\\b(?:屑芯泄|屑芯褟)\\s+(?:薪邪褔邪谢褜薪懈泻|屑械薪械写卸械褉|泻芯谢谢械谐邪|写褉褍谐|锌邪褉褌薪褢褉|卸械薪邪|屑褍卸|泻谢懈械薪褌)\\b",
        "(?i)\\b(?:褉邪斜芯褌邪褞 褋|胁褋褌褉械褔邪 褋|褋芯蟹胁芯薪 褋)\\b\\s+[袗-携衼A-Z]"
      ]
    },
    "project": {
      "description": "Project names, repos, tools in active use",
      "base_importance": 1.3,
      "patterns_en": [
        "(?i)\\b(?:project|repo|repository|codebase|app|service|bot|channel)\\s*(?:called|named|is)?\\s*[\"'`]?\\w",
        "(?i)\\b(?:github|gitlab|bitbucket)\\.\\w+/\\w+",
        "(?i)\\b@\\w+\\b"
      ],
      "patterns_ru": [
        "(?i)\\b(?:锌褉芯械泻褌|褉械锌芯|斜芯褌|泻邪薪邪谢|褋械褉胁懈褋)\\s+[\"'`芦]?\\w",
        "(?i)\\b@\\w+\\b"
      ]
    },
    "tech_stack": {
      "description": "Technologies, tools, frameworks in use",
      "base_importance": 1.0,
      "patterns_en": [
        "(?i)\\b(?:using|use|run|deploy|built with|stack|framework)\\s+\\w+",
        "(?i)\\b(?:python|node|rust|go|typescript|react|vue|docker|k8s|postgres|redis|sqlite)\\b"
      ],
      "patterns_ru": [
        "(?i)\\b(?:懈褋锌芯谢褜蟹褍褞|懈褋锌芯谢褜蟹褍械屑|锌懈褕褍 薪邪|写械锌谢芯褞 薪邪|褋褌械泻)\\s+\\w+",
        "(?i)\\b(?:python|node|rust|go|typescript|react|vue|docker|postgres|redis|sqlite)\\b"
      ]
    }
  },
  "explicit_remember": {
    "patterns_en": [
      "(?i)\\b(?:remember\\s+(?:this|that)|don'?t\\s+forget|keep\\s+in\\s+mind|note\\s+(?:this|that))\\b",
      "(?i)\\b(?:save\\s+(?:this|that)|store\\s+(?:this|that)|write\\s+(?:this|that)\\s+down)\\b",
      "(?i)\\bfor\\s+(?:future|later)\\s+reference\\b"
    ],
    "patterns_ru": [
      "(?i)\\b(?:蟹邪锌芯屑薪懈|薪械\\s+蟹邪斜褍写褜|懈屑械泄\\s+胁\\s+胁懈写褍|蟹邪屑械褌褜|褍褔褌懈)\\b",
      "(?i)\\b(?:褋芯褏褉邪薪懈|蟹邪锌懈褕懈|蟹邪褎懈泻褋懈褉褍泄)\\b",
      "(?i)\\b(?:薪邪\\s+斜褍写褍褖械械|写谢褟\\s+褋锌褉邪胁泻懈)\\b"
    ],
    "importance_boost": 1.5
  },
  "explicit_forget": {
    "patterns_en": [
      "(?i)\\b(?:forget\\s+(?:about|that)|remove\\s+from\\s+memory|delete\\s+(?:this|that))\\b",
      "(?i)\\b(?:no\\s+longer|not\\s+anymore|outdated|obsolete)\\b"
    ],
    "patterns_ru": [
      "(?i)\\b(?:蟹邪斜褍写褜|褍写邪谢懈|褍斜械褉懈\\s+懈蟹\\s+锌邪屑褟褌懈)\\b",
      "(?i)\\b(?:褍卸械\\s+薪械\\s+邪泻褌褍邪谢褜薪芯|褍褋褌邪褉械谢芯|薪械邪泻褌褍邪谢褜薪芯|斜芯谢褜褕械\\s+薪械)\\b"
    ]
  }
}
