# Optional curated-source adapter. AIHOT is one source, not the project identity.
CURATED_AIHOT_URL=https://aihot.virxact.com/
CURATED_AIHOT_LIMIT=3

# WeChat Official Account credentials.
# Fill these in .env, not in code.
WECHAT_APPID=
WECHAT_APPSECRET=
# WeChat author field has a short length limit. Keep this within 8 Chinese characters.
WECHAT_AUTHOR=
WECHAT_CREATION_SOURCE=个人观点，仅供参考

# Optional emergency fallback: upload a permanent cover image once in WeChat and put its media_id here.
WECHAT_THUMB_MEDIA_ID=

# Default is 0. Keep this off so each article must provide a model-generated
# coverImagePath produced by image2/imagegen and saved under data/images/.
ALLOW_STATIC_COVER_FALLBACK=0

# Emergency fallback: local JPG/PNG to upload as permanent material only when
# ALLOW_STATIC_COVER_FALLBACK=1.
DEFAULT_COVER_PATH=assets/default-cover.png

# Keep as 1 until you have verified the generated article payloads.
DRY_RUN=1
