{
  "version": "4.0.0",
  "description": "yaoyao-memory 监控阈值配置",
  
  "health_thresholds": {
    "system_health_score": {
      "critical": 60,
      "warning": 80,
      "good": 90
    },
    "error_count": {
      "critical": 10,
      "warning": 5,
      "good": 0
    },
    "search_latency_ms": {
      "critical": 100,
      "warning": 50,
      "good": 10
    },
    "cache_hit_rate": {
      "critical": 40,
      "warning": 60,
      "good": 80
    }
  },
  
  "coverage_thresholds": {
    "l0_conversations": {
      "minimum": 60,
      "target": 80,
      "unit": "percent"
    },
    "l1_memories": {
      "minimum": 95,
      "target": 100,
      "unit": "percent"
    }
  },
  
  "storage_thresholds": {
    "database_size_mb": {
      "critical": 100,
      "warning": 50,
      "good": 20
    },
    "wal_size_mb": {
      "critical": 50,
      "warning": 20,
      "good": 5
    },
    "backup_age_days": {
      "critical": 7,
      "warning": 3,
      "good": 1
    }
  },
  
  "sync_thresholds": {
    "ima_sync_age_hours": {
      "critical": 48,
      "warning": 24,
      "good": 12
    },
    "nas_sync_age_hours": {
      "critical": 24,
      "warning": 12,
      "good": 8
    }
  },
  
  "alert_actions": {
    "critical": ["push_notification", "log_error", "auto_fix"],
    "warning": ["push_notification", "log_warning"],
    "good": ["log_info"]
  }
}
