{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/peixl/ifq-design-skills/assets/templates/templates.schema.json",
  "title": "IFQ Design Skills Template Index",
  "type": "object",
  "required": ["version", "author", "description", "qualityContract", "modeRoutes", "templates"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "author": { "type": "string" },
    "description": { "type": "string" },
    "qualityContract": {
      "type": "object",
      "required": ["thesis", "defaultLoop", "minimumEvidence", "clawhubScope"],
      "additionalProperties": true,
      "properties": {
        "thesis": { "type": "string" },
        "defaultLoop": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 5
        },
        "minimumEvidence": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 4
        },
        "clawhubScope": { "type": "string" }
      }
    },
    "modeRoutes": {
      "type": "object",
      "patternProperties": {
        "^M-(0[1-9]|1[0-2])$": {
          "type": "object",
          "required": ["label", "primaryTemplate", "fallbackTemplates", "requiredReferences", "outputBoundary"],
          "additionalProperties": true,
          "properties": {
            "label": { "type": "string" },
            "primaryTemplate": { "type": "string" },
            "fallbackTemplates": {
              "type": "array",
              "items": { "type": "string" }
            },
            "requiredReferences": {
              "type": "array",
              "items": { "type": "string", "pattern": "^references/.+\\.md$" },
              "minItems": 1
            },
            "outputBoundary": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "mode", "name", "file", "viewport", "notes"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "mode": {
            "type": "array",
            "items": { "type": "string", "pattern": "^M-(0[1-9]|1[0-2])$" },
            "minItems": 1
          },
          "name": { "type": "string" },
          "file": { "type": "string", "pattern": "^assets/templates/.+\\.html$" },
          "viewport": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
