        "openWorldHint": false
      }
    },
    {
      "name": "query_consistency",
      "display_name": "一致性评价查询",
      "description": "查询通过仿制药质量和疗效一致性评价的品种。返回药品名称、规格、企业名称、批准文号、批准日期等信息。",
      "inputSchema": {
