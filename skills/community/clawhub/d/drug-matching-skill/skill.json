    {
      "name": "query_certification",
      "display_name": "国际认证查询",
      "description": "查询通过制剂国际认证（FDA/EU等）的企业。返回企业名称、认证类型、认证时间、剂型等信息。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
