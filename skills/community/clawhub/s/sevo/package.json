    "code-quality",
    "ci-cd",
    "agent-pipeline",
    "spec-driven",
    "ai-coding",
    "development-automation"
  ],
  "author": "OpenClaw SEVO Team <yuchangxu1989@gmail.com>",
  "license": "MIT",
  "files": [
    "dist/",
    "bin/",
    "templates/",
    "scripts/",
    "index.js",
    "openclaw.plugin.json",
    "bridge.js",
    "label-protocol.js",
    "methodology.js",
    "role-templates.js",
    "sevo-init.js",
    "task-mapper.js",
    "utils.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.8.3",
