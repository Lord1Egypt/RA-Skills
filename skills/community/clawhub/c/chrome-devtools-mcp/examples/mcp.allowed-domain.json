{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--allowed-url-pattern=https://example.com/*",
        "--blocked-url-pattern=file://*",
        "--no-usage-statistics",
        "--no-performance-crux"
      ]
    }
  }
}
