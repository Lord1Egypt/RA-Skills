{
  "name": "timeline-chart",
  "version": "1.0.0",
  "description": "专业时间线推进图制作技能，支持中文、数字完整显示，动态布局避免文字溢出",
  "author": "制图创作引领大师",
  "tags": ["时间线", "图表", "可视化", "项目管理", "流程图"],
  "category": "visualization",
  "keywords": [
    "timeline",
    "时间线",
    "推进图",
    "项目进度",
    "历史事件",
    "流程演进",
    "里程碑"
  ],
  "useCases": [
    "项目时间线展示",
    "历史事件梳理",
    "流程演进图",
    "里程碑展示",
    "决策流程图"
  ],
  "features": [
    "自动解析时间线事件数据",
    "智能布局时间节点和事件卡片",
    "支持中文、数字、标点符号完整显示",
    "动态调整卡片高度避免文字溢出",
    "专业商务风格设计",
    "颜色编码区分节点类型"
  ],
  "requirements": {
    "fonts": [
      "fonts-noto-cjk",
      "fonts-wqy-zenhei"
    ],
    "python": [
      "Pillow>=8.0.0"
    ]
  },
  "examples": [
    {
      "title": "项目时间线",
      "events": [
        ["2018-07-24", "项目启动", "启动", null],
        ["2018-08-01", "招标发布", "招标", null],
        ["2018-09-28", "合同签订", "签订", "最终签约：XX公司"]
      ]
    }
  ]
}
