{
  "telegram": {
    "enabled": true,
    "bot_token": "${TELEGRAM_BOT_TOKEN}",
    "chat_id": "${TELEGRAM_CHAT_ID}",
    "parse_mode": "Markdown",
    "disable_web_page_preview": true
  },
  "feishu": {
    "enabled": false,
    "app_id": "${FEISHU_APP_ID}",
    "app_secret": "${FEISHU_APP_SECRET}",
    "chat_id": "${FEISHU_CHAT_ID}"
  }
}
