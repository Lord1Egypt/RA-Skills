{
  "env": {
    "ANTHROPIC_BASE_URL": "https://ark.cn-beijing.volces.com/api/plan",
    "ANTHROPIC_MODEL": "ark-code-latest",
    "ANTHROPIC_SMALL_FAST_MODEL": "ark-code-latest",
