{
  "name": "soul-fireseed",
  "version": "2.1.0",
  "description": "火种·灵魂 v2.1 — 人格建模与记忆沉淀。双模式：对话提取+记忆分析。支持后台自动提取(每周/每日)。",
  "author": "topofthesky",
  "license": "MIT",
  "python_version": ">=3.8",
  "dependencies": [
    "sentence-transformers>=2.2.0",
    "scikit-learn>=1.0.0",
    "numpy>=1.21.0",
    "pandas>=1.3.0",
    "jinja2>=3.0.0"
  ],
  "entry_point": "lib.extractor:FossilExtractor",
  "triggers": [
    "点燃火种",
    "启动火种",
    "火种启动",
    "灵魂启动",
    "灵魂",
    "人格建模",
    "记忆沉淀",
    "思维化石",
    "数字孪生"
  ],
  "capabilities": [
    "六维度化石提取",
    "人格模型蒸馏",
    "语义相似度检索",
    "置信度校准",
    "演化轨迹追踪",
    "人格快照卡片输出"
  ],
  "bus_integration": false,
  "standalone": true,
  "features": {
    "parallel_extraction": true,
    "semantic_search": true,
    "contradiction_detection": true,
    "evolution_tracking": true,
    "auto_backup": true
  },
  "storage": {
    "fossils": "user-data/fossils/",
    "persona": "user-data/persona/",
    "backups": "user-data/backups/"
  }
}
