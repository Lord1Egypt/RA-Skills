{
  "name": "@robot-id-card/sdk",
  "version": "0.2.0",
  "description": "Website SDK for verifying Robot ID Card bot identities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node ../../node_modules/vitest/vitest.mjs run src",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "fastify": ">=4"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
