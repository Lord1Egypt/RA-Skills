{
  "name": "pg-memory",
  "version": "2.7.3",
  "description": "PostgreSQL-based structured memory system for OpenClaw - Multi-Instance Edition",
  "author": "OpenClaw Contributors <contributors@openclaw.ai>",
  "license": "MIT",
  "created": "2026-02-25",
  "updated": "2026-03-03",
  "requires": {
    "postgresql": ">=18.0",
    "python": ">=3.10",
    "packages": ["psycopg2-binary"]
  },
  "features": [
    "Connection pooling (ThreadedConnectionPool)",
    "Rate limiting (configurable)",
    "Input validation (content, tags, importance)",
    "Batch operations (up to 100/transaction)",
    "Query caching (LRU + TTL)",
    "Path traversal protection",
    "SQL injection protection",
    "Observation Protocol (auto-create for new projects/tasks)",
    "Status management (active, ongoing, resolved, superseded)",
    "Exchange ID tracking (link to chat messages)",
    "Related observations (bidirectional linking)",
    "Templates (Bug Report, Decision Record, Project Kickoff, Milestone)",
    "Summaries (auto-generated, ADDITIONAL to originals)",
    "Conflict detection (find contradictions)",
    "Follow-up reminders (stale observation alerts)",
    "Bulk markdown import",
    "Observation chains (project/workflow tracking)",
    "Natural Language queries (Ollama-powered SQL generation)",
    "NLQueryResult structured returns",
    "PostgreSQL 18 compatibility",
    "pgvector integration (1024-dim BGE-M3 via Ollama)",
    "Table partitioning (raw_exchanges by month)",
    "Duplicate detection (full-text similarity)",
    "Tag autocomplete (content-based + existing tags)",
    "Backup & Restore (pg_dump integration)",
    "JSON export/import (machine-readable)",
    "Automated daily backups",
    "Multi-instance support (shared database)",
    "Auto-generated instance IDs (UUID per machine)",
    "Agent labeling (human-readable instance names)",
    "Concurrent access safety (UPSERT patterns)",
    "Instance statistics tracking",
    "Performance optimizations (50% storage reduction, 2-5x faster semantic search)",
    "Adaptive IVFFLAT index tuning (lists parameter based on row count)"
  ],
  "files": [
    "SKILL.md",
    "README.md",
    "package.json",
    "LICENSE",
    ".gitignore",
    "install.sh",
    "scripts/pg_memory.py",
    "scripts/pg-memory-cli",
    "scripts/nl_query.py",
    "scripts/backup_manager.py",
    "scripts/init_memory_schema.sql",
    "scripts/init_memory_schema_v20.sql",
    "scripts/schema_v2_5_partitioning.sql",
    "scripts/schema_v2_7_1_embedding_fix.sql",
    "references/MEMORY_ARCHITECTURE.md"
  ],
  "keywords": [
    "postgresql",
    "memory",
    "observations",
    "chains",
    "templates",
    "summaries",
    "conflicts",
    "reminders",
    "knowledge-base",
    "duplicates",
    "autocomplete",
    "backup",
    "restore",
    "export",
    "import"
  ]
}
