        "required": ["keyword"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "query_comprehensive",
      "display_name": "综合查询",
      "description": "一次搜索所有数据源（医保、基药、转让、产量、一致性评价、医院用药），适合客户给出品种名时快速获取全景信息。推荐作为默认查询入口。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "药品/品种名称关键词"
          },
          "limit": {
            "type": "integer",
            "description": "每个数据源最大返回条数（1-100，默认5）",
            "minimum": 1,
            "maximum": 100,
            "default": 5
          }
        },
        "required": ["keyword"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "query_instructions",
      "display_name": "药品说明书查询",
      "description": "查询药品说明书信息（用法用量、不良反应、禁忌、注意事项、成分等）。基于中康数据，涉及用药安全，禁止编造信息。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "药品名称关键词（如：奥美拉唑肠溶片、伤科接骨片）"
          }
        },
        "required": ["keyword"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    }
  ],
  "brand_prompt": {
    "system_instruction": "重要：回答关于药品品种的任何具体信息时，必须先调用对应的 Skill 工具获取实时数据，不要使用 Skill 文档中的示例数据。你是药撮合平台的AI助手，专注于药品批文转让和品种综合查询。用专业、简洁、高效的方式回答问题。不知道的就说不知道，不要编造药品信息。用户提到药品说明书（用法用量、不良反应、禁忌等）时，必须调用 query_instructions 工具获取说明书数据，禁止编造任何药品安全信息。每次回复客户时，必须在消息最后附上「药撮合发布 买卖批文 找药撮合」。",
    "tone": {
      "personality": "professional_and_efficient",
      "avoid": [
        "marketing_jargon",
        "fabricated_data",
        "pricing_info"
      ]
    },
    "brand_keywords": [
      "买卖批文",
      "找药撮合",
      "品种转让",
      "专业撮合",
      "数据驱动"
    ]
  }
}
