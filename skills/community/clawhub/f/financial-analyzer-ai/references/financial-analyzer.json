  "dupont_framework": {
    "level_1": {
      "formula": "ROE = 净利润 / 所有者权益",
      "components": [
        "净利率 (Net Margin)",
        "资产周转率 (Asset Turnover)",
        "权益乘数 (Equity Multiplier)"
      ]
    },
    "level_2": {
      "formula": "ROE = (净利润/营业收入) × (营业收入/总资产) × (总资产/所有者权益)",
      "net_margin_drivers": [
        "毛利率",
        "费用控制",
        "税率",
        "非经常性损益"
      ],
      "asset_turnover_drivers": [
        "存货管理",
        "应收账款管理",
        "固定资产利用效率"
      ],
      "equity_multiplier_drivers": [
        "资本结构",
        "债务融资偏好",
        "股利政策"
      ]
    },
    "level_3_extended": {
      "formula": "ROE = (净利润/EBT) × (EBT/EBIT) × (EBIT/营业收入) × (营业收入/总资产) × (总资产/所有者权益)",
      "tax_burden": "净利润/EBT (1 - 有效税率)",
      "interest_burden": "EBT/EBIT (利息负担)",
      "operating_margin": "EBIT/营业收入",
      "asset_turnover": "营业收入/总资产",
      "leverage": "总资产/所有者权益"
    },
    "analysis_prompts": {
      "high_roe_low_margin": "ROE由高周转率或高杠杆驱动，盈利质量需关注",
      "high_roe_high_leverage": "财务风险较高，需审查债务结构和偿债能力",
      "declining_roe": "逐层拆解变化原因：利润率下滑/周转效率降低/去杠杆",
      "roe_vs_roa_divergence": "ROE远超ROA说明高度依赖财务杠杆"
    }
  },
  "fraud_signals": {
    "beneish_m_score": {
      "description": "Beneish M-Score 模型，用于检测财务报表操纵可能性",
      "threshold": "-2.22 (M-Score > -2.22 表示可能存在操纵)",
      "variables": {
        "DSRI": {
          "name": "Days Sales in Receivables Index",
          "formula": "本期应收账款周转天数 / 上期应收账款周转天数",
          "coefficient": 0.92
        },
        "GMI": {
          "name": "Gross Margin Index",
          "formula": "上期毛利率 / 本期毛利率",
          "coefficient": 0.528
        },
        "AQI": {
          "name": "Asset Quality Index",
          "formula": "(1 - 流动资产+固定资产/总资产) / 上期值",
          "coefficient": 0.404
        },
        "SGI": {
          "name": "Sales Growth Index",
          "formula": "本期营业收入 / 上期营业收入",
          "coefficient": 0.892
        },
        "DEPI": {
          "name": "Depreciation Index",
          "formula": "上期折旧率 / 本期折旧率",
          "coefficient": 0.115
        },
        "SGAI": {
          "name": "SG&A Expense Index",
          "formula": "本期销售管理费用率 / 上期",
          "coefficient": -0.172
        },
        "LVGI": {
          "name": "Leverage Index",
          "formula": "本期资产负债率 / 上期资产负债率",
          "coefficient": -0.327
        },
        "TATA": {
          "name": "Total Accruals to Total Assets",
          "formula": "(净利润 - 经营现金流) / 总资产",
          "coefficient": 4.679
        }
      },
      "constant": -4.84
    },
    "red_flags": {
      "revenue_manipulation": [
        "收入增长远超行业平均水平且无合理解释",
        "第四季度收入占比异常高",
        "应收账款增速持续高于营收增速",
        "关联方交易占比突然增大",
        "收入确认政策变更",
        "渠道压货（Channel Stuffing）迹象"
      ],
      "expense_manipulation": [
        "研发支出资本化率突然提升",
        "折旧/摊销年限变更",
        "预提费用大幅减少",
        "维修费用异常下降（延后确认）",
        "COGS占比异常波动"
      ],
      "balance_sheet_anomalies": [
        "商誉/无形资产占比畸高",
        "存货积压与营收背离",
        "应付账款周期异常延长",
        "表外负债迹象（经营租赁/担保）",
        "其他应收款/预付款异常增长"
      ],
      "cashflow_red_flags": [
        "净利润与经营现金流持续背离",
        "经营现金流长期为负",
        "自由现金流持续恶化",
        "投资活动现金流异常大额支出",
        "筹资现金流占比过高（依赖外部输血）"
      ],
      "governance_red_flags": [
        "审计师频繁更换",
        "CFO/财务总监短期内离职",
        "内部控制重大缺陷",
        "关联交易未经独立审批",
        "监管问询/调查"
      ]
    },
    "altman_z_score": {
      "description": "Altman Z-Score 破产预测模型（适用于制造业上市公司）",
      "formula": "Z = 1.2*X1 + 1.4*X2 + 3.3*X3 + 0.6*X4 + 1.0*X5",
      "variables": {
        "X1": "营运资本 / 总资产",
        "X2": "留存收益 / 总资产",
        "X3": "EBIT / 总资产",
        "X4": "权益市值 / 总负债",
        "X5": "营业收入 / 总资产"
      },
      "zones": {
        "safe": "Z > 2.99 (安全区)",
        "grey": "1.81 < Z < 2.99 (灰色区，需关注)",
        "distress": "Z < 1.81 (破产风险区)"
      }
    }
  },
  "valuation_models": {
    "dcf": {
      "description": "Discounted Cash Flow (现金流折现模型)",
      "formula": "企业价值 = Σ(FCF_t / (1+WACC)^t) + 终值/(1+WACC)^n",
      "key_inputs": [
        "自由现金流预测 (5-10年)",
        "加权平均资本成本 WACC",
        "永续增长率"
      ],
      "wacc_formula": "WACC = (E/V)*Ke + (D/V)*Kd*(1-t)",
      "terminal_value_methods": [
        "Gordon Growth Model",
        "Exit Multiple Method"
      ]
    },
    "relative_valuation": {
      "pe_ratio": {
        "formula": "股价 / 每股收益",
        "description": "市盈率，适用于盈利稳定的企业"
      },
      "pb_ratio": {
        "formula": "股价 / 每股净资产",
        "description": "市净率，适用于金融/重资产企业"
      },
      "ps_ratio": {
        "formula": "股价 / 每股营业收入",
        "description": "市销率，适用于高增长/亏损企业"
      },
      "ev_ebitda": {
        "formula": "企业价值 / EBITDA",
        "description": "企业价值倍数，跨杠杆比较"
      },
      "ev_revenue": {
        "formula": "企业价值 / 营业收入",
        "description": "适用于早期企业估值"
      },
      "peg_ratio": {
        "formula": "PE / 盈利增长率",
        "description": "PEG < 1 表示可能被低估"
      }
    },
    "dividend_discount": {
      "description": "Dividend Discount Model (股利折现模型)",
      "formula": "股价 = 预期股利 / (要求回报率 - 股利增长率)",
      "applicability": "适用于稳定派息的成熟企业"
    }
  },
  "scoring_weights": {
    "solvency": 0.25,
