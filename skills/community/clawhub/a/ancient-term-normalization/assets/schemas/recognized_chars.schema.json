{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RecognizedChars",
  "type": "object",
  "required": ["recognized_chars"],
  "properties": {
    "recognized_chars": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}