  "literature_search": {
    "description": "学术文献检索",
    "tools": [
      {
        "name": "PubMed E-utilities",
        "priority": 1,
        "invocation": "exec: curl -s 'https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi?db=pubmed&retmax=20&api_key=${NCBI_API_KEY}&term=QUERY' | 然后 efetch 获取详情",
        "strength": "医学文献金标准，完整元数据（PMID/DOI/作者/摘要）",
        "limitation": "仅生物医学，无AI摘要",
        "free": true,
        "notes": "API Key 已在环境变量 NCBI_API_KEY"
      },
      {
        "name": "Semantic Scholar API",
        "priority": 2,
        "invocation": "exec: curl -s -H 'x-api-key: ${SEMANTIC_SCHOLAR_API_KEY}' 'https://api.semanticscholar.org/graph/v1/paper/search?query=QUERY&limit=20&fields=title,authors,year,abstract,externalIds,citationCount'",
        "strength": "AI推荐、引用分析、跨学科覆盖",
        "limitation": "元数据不如PubMed完整",
        "free": true
      },
      {
        "name": "tavily_search",
        "priority": 3,
        "invocation": "tool: tavily_search(query=QUERY, search_depth='advanced', max_results=15)",
        "strength": "AI深度搜索+摘要，适合非医学领域",
        "limitation": "非学术专用，付费",
        "free": false
      },
      {
        "name": "TinyFish Search",
        "priority": 4,
        "invocation": "exec: curl -s -H 'X-API-Key: ${TINYFISH_API_KEY}' 'https://api.search.tinyfish.ai?query=QUERY'",
        "strength": "免费备用",
        "limitation": "仅返回10条，无AI摘要",
        "free": true
      }
    ]
  },

  "literature_fetch": {
    "description": "获取文献全文/详情",
    "tools": [
      {
        "name": "PubMed efetch",
        "priority": 1,
        "invocation": "exec: curl -s 'https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi?db=pubmed&id=PMID&rettype=abstract&api_key=${NCBI_API_KEY}'",
        "strength": "获取完整摘要、MeSH词、作者列表",
        "limitation": "无全文PDF",
        "free": true
      },
      {
        "name": "Semantic Scholar Paper",
        "priority": 2,
        "invocation": "exec: curl -s -H 'x-api-key: ${SEMANTIC_SCHOLAR_API_KEY}' 'https://api.semanticscholar.org/graph/v1/paper/PMID?fields=title,abstract,authors,year,externalIds,citationCount,references'",
        "strength": "获取引用链和推荐文献",
        "limitation": "部分论文无摘要",
        "free": true
      },
      {
        "name": "web_fetch",
        "priority": 3,
        "invocation": "tool: web_fetch(url=URL, extractMode='markdown')",
        "strength": "抓取任意网页内容",
        "limitation": "无法处理JS渲染页面",
        "free": true
      },
      {
        "name": "TinyFish Fetch",
        "priority": 4,
        "invocation": "exec: curl -s -X POST -H 'Content-Type: application/json' -H 'X-API-Key: ${TINYFISH_API_KEY}' -d '{\"urls\":[\"URL\"],\"format\":\"markdown\"}' 'https://api.fetch.tinyfish.ai'",
        "strength": "支持JS渲染页面",
        "limitation": "一次最多10个URL",
        "free": true
      }
    ]
  },

