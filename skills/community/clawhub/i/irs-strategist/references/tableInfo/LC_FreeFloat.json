    {
        "columnOrderId": 18,
        "columnName": "AdjFreeFloatRatio",
        "columnChiName": "自由流通比例(归档后)(%)",
        "columnType": "decimal(10,6)",
        "isNullable": 1,
        "remark": "自由流通比例(%)按如下规则进行分级靠档，获得归档后的自由流通比例(%)：自由流通比例(%)<=15,上调至最接近的整数值；\n自由流通比例（%）大于15且小于等于20时，归档为20；\n自由流通比例（%）大于20小于等于30时，归档为30；\n自由流通比例（%）大于30小于等于40时，归档为40；\n自由流通比例（%）大于40小于等于50时，归档为50；\n自由流通比例（%）大于50小于等于60时，归档为60；\n自由流通比例（%）大于60小于等于70时，归档为70；\n自由流通比例（%）大于70小于等于80时，归档为80；\n自由流通比例（%）大于80小于等于100时，归档为100",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "100.0",
        "remarkNo": "注6"
    },
