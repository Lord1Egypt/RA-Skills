{
    "name":  "amazon_contact_flow",
    "version":  "1.1.0",
    "description":  "Opens order detail page, navigates Amazon contact flow, and types a message for after-sales requests.",
    "allowedTools":  [
                         "browser.click",
                         "browser.click_text",
                         "browser.contact_flow",
                         "browser.type",
                         "browser.type_message",
                         "browser.wait",
                         "browser.query",
                         "browser.scroll"
                     ],
    "input_schema":  {
                         "type":  "object",
                         "properties":  {
                                            "order_id":  {
                                                             "type":  "string"
                                                         },
                                            "details_url":  {
                                                                "type":  "string"
                                                            },
                                            "message":  {
                                                            "type":  "string"
                                                        },
                                            "auto_send":  {
                                                              "type":  "boolean"
                                                          },
                                            "origin":  {
                                                           "type":  "string"
                                                       },
                                            "confirm_send":  {
                                                                 "type":  "boolean",
                                                                 "description":  "Must be true together with auto_send=true to actually send."
                                                             }
                                        }
                     },
    "output_schema":  {
                          "type":  "object",
                          "properties":  {
                                             "detailUrl":  {
                                                               "type":  "string"
                                                           },
                                             "contactUrl":  {
                                                                "type":  "string"
                                                            },
                                             "messagingUrl":  {
                                                                  "type":  "string"
                                                              },
                                             "conversationUrl":  {
                                                                     "type":  "string"
                                                                 },
                                             "detailTabId":  {
                                                                 "type":  "number"
                                                             },
                                             "messagingTabId":  {
                                                                    "type":  "number"
                                                                }
                                         }
                      },
    "notes":  "Amazon contact flow automation. details_url must be an https amazon.* URL. Message auto-send is disabled unless auto_send=true and confirm_send=true.",
    "examples":  [
                     {
                         "input":  {
                                       "order_id":  "114-1234567-1234567",
                                       "details_url":  "https://www.amazon.com/your-orders/order-details?orderID=114-1234567-1234567",
                                       "message":  "I noticed a price drop after purchase and request a refund for the difference.",
                                       "auto_send":  false
                                   },
                         "output":  {
                                        "detailUrl":  "https://www.amazon.com/your-orders/order-details?orderID=114-1234567-1234567",
                                        "contactUrl":  "https://www.amazon.com/gp/help/contact/contact.html",
                                        "messagingUrl":  "https://www.amazon.com/gp/message?threadId=EXAMPLE",
                                        "conversationUrl":  "https://www.amazon.com/gp/message?threadId=EXAMPLE",
                                        "detailTabId":  123,
                                        "messagingTabId":  456
                                    }
                     }
                 ],
    "id":  "amazon_contact_flow"
}
