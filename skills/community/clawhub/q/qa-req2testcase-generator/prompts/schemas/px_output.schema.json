{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "px_output.schema.json",
  "title": "PX 图片理解与测试增强输出 Schema",
  "description": "对齐技术方案 v1.5 §8.1（单图输出）+ §8.3（聚合输出），schema_version 1.4.0",

  "definitions": {

    "classification": {
      "type": "object",
      "description": "图片分类信息",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ui_mockup", "flowchart", "state_diagram", "table_rule", "annotated_screenshot", "api_snapshot", "report_chart", "unknown"],
          "description": "图片类型（8种+unknown）"
        },
        "value_level": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "价值等级"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "分类置信度"
        },
        "classification_method": {
          "type": "string",
          "enum": ["vision", "ocr", "ocr_context", "context_inference", "none"],
          "description": "分类方法（AB-01修复：补充ocr/ocr_context枚举值）"
        },
        "model_used": {
          "type": "string",
          "description": "使用的模型标识"
        }
      },
      "required": ["type", "value_level", "confidence", "classification_method"]
    },

    "extraction_mode": {
      "type": "string",
      "enum": ["vision", "ocr", "ocr_degraded", "context_only", "skipped"],
      "description": "提取模式枚举"
    },

    "processing_status": {
      "type": "string",
      "enum": [
        "success",
        "success_degraded",
        "success_vision_failed",
        "success_ocr_failed",
        "skipped",
        "skipped_low_value",
        "skipped_no_vision",
        "skipped_unknown",
        "failed"
      ],
      "description": "处理状态枚举"
    },

    "token_cost": {
      "type": "object",
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 }
      },
      "required": ["input_tokens", "output_tokens"]
    },

    "quality_score": {
      "type": "object",
      "description": "质量评分",
      "properties": {
        "completeness": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "actionability": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "non_redundancy": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "required": ["completeness", "actionability", "non_redundancy"]
    },

    "single_image_output": {
      "type": "object",
      "description": "单图输出（§8.1）",
      "properties": {
        "schema_version": { "type": "string", "const": "1.4.0" },
        "image_id": { "type": "string", "pattern": "^IMG-\\d+$" },
        "file_path": { "type": "string" },
        "classification": { "$ref": "#/definitions/classification" },
        "extraction_mode": { "$ref": "#/definitions/extraction_mode" },
        "processing_status": { "$ref": "#/definitions/processing_status" },
        "token_cost": { "$ref": "#/definitions/token_cost" },
        "content_hash": { "type": "string" },
        "section": { "type": "string" },
        "summary": { "type": "string" },
        "extracted_rules": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 10
        },
        "derived_features": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 15
        },
        "derived_test_points": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 10
        },
        "derived_risks": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5
        },
        "derived_questions": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5
        },
        "type_specific": { "type": "object" },
        "ocr_text": {
          "type": "string",
          "description": "OCR识别原始文本，仅OCR模式存在（AB-01修复）"
        },
        "corrected_text": {
          "type": "string",
          "description": "纠错后文本，仅OCR模式存在（AB-01修复）"
        },
        "text_image_conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "image_id": { "type": "string" },
              "conflict_type": { "type": "string" },
              "description": { "type": "string" },
              "severity": { "type": "string", "enum": ["high", "medium", "low"] }
            }
          },
          "description": "图文冲突列表（AB-01修复：从string改为object）"
        },
        "quality_score": { "$ref": "#/definitions/quality_score" },
        "degradation_notice": {
          "type": ["string", "null"],
          "description": "降级说明，视觉模式下为 null"
        },
        "before_text": { "type": "string" },
        "after_text": { "type": "string" },
        "caption": { "type": "string" }
      },
      "required": [
        "schema_version", "image_id", "classification",
        "extraction_mode", "processing_status", "section"
      ]
    },

    "model_capability": {
      "type": "object",
      "description": "模型能力探测结果",
      "properties": {
        "model_id": { "type": "string" },
        "vision_supported": { "type": "boolean" },
        "detection_method": { "type": "string" },
        "detection_time": { "type": "string", "format": "date-time" }
      },
      "required": ["model_id", "vision_supported", "detection_method"]
    },

    "mode_summary": {
      "type": "object",
      "description": "处理模式统计",
      "properties": {
        "active_mode": {
          "type": "string",
          "enum": ["vision", "ocr", "context_only"]
        },
        "vision_count": { "type": "integer", "minimum": 0 },
        "ocr_count": { "type": "integer", "minimum": 0 },
        "ocr_degraded_count": { "type": "integer", "minimum": 0 },
        "context_only_count": { "type": "integer", "minimum": 0 },
        "skipped_count": { "type": "integer", "minimum": 0 }
      },
      "required": ["active_mode", "vision_count", "ocr_count", "context_only_count", "skipped_count"]
    },

    "processing_summary": {
      "type": "object",
      "description": "处理统计",
      "properties": {
        "total_images": { "type": "integer", "minimum": 0 },
        "high_value": { "type": "integer", "minimum": 0 },
        "medium_value": { "type": "integer", "minimum": 0 },
        "low_value": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "total_input_tokens": { "type": "integer", "minimum": 0 },
        "total_output_tokens": { "type": "integer", "minimum": 0 }
      },
      "required": ["total_images", "high_value", "medium_value", "low_value"]
    },

    "aggregate_derived": {
      "type": "object",
      "description": "聚合的 derived_* 数据",
      "properties": {
        "total_derived_features": { "type": "integer", "minimum": 0 },
        "total_derived_test_points": { "type": "integer", "minimum": 0 },
        "total_derived_risks": { "type": "integer", "minimum": 0 },
        "total_derived_questions": { "type": "integer", "minimum": 0 },
        "derived_features": { "type": "array", "items": { "type": "string" } },
        "derived_test_points": { "type": "array", "items": { "type": "string" } },
        "derived_risks": { "type": "array", "items": { "type": "string" } },
        "derived_questions": { "type": "array", "items": { "type": "string" } }
      },
      "required": [
        "total_derived_features", "total_derived_test_points",
        "total_derived_risks", "total_derived_questions"
      ]
    }
  },

  "oneOf": [
    {
      "title": "单图输出",
      "description": "§8.1 单图输出 Schema",
      "$ref": "#/definitions/single_image_output"
    },
    {
      "title": "聚合输出",
      "description": "§8.3 聚合输出 Schema",
      "type": "object",
      "properties": {
        "schema_version": { "type": "string", "const": "1.4.0" },
        "task_id": { "type": "string" },
        "model_capability": { "$ref": "#/definitions/model_capability" },
        "mode_summary": { "$ref": "#/definitions/mode_summary" },
        "processing_summary": { "$ref": "#/definitions/processing_summary" },
        "degradation_summary": {
          "type": ["string", "null"],
          "description": "任务级降级说明"
        },
        "aggregate": { "$ref": "#/definitions/aggregate_derived" },
        "text_image_conflicts": {
          "type": "array",
          "items": { "type": "object" }
        },
        "coverage_matrix": {
          "type": "object",
          "description": "预留字段，当前版本不生成，将在后续版本实现（AB-03备注）"
        },
        "images": {
          "type": "array",
          "items": { "$ref": "#/definitions/single_image_output" }
        }
      },
      "required": [
        "schema_version", "task_id", "model_capability",
        "mode_summary", "processing_summary", "images"
      ]
    }
  ]
}
