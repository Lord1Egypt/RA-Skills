    "C":  {"min_score": 40, "description": "有待改善", "recommendation": "建议先改善财务表现再考虑上市"},
    "D":  {"min_score": 25, "description": "暂不可行", "recommendation": "需大幅改善财务指标和治理结构"},
    "E":  {"min_score": 0,  "description": "不建议", "recommendation": "当前财务状况远低于上市标准"}
