{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meta Ads CLI guarded command plan",
  "type": "object",
  "required": ["goal", "commands"],
  "properties": {
    "goal": {"type": "string"},
    "requires_user_approval": {"type": "boolean", "default": true},
    "allow_active": {"type": "boolean", "default": false},
    "allow_budget": {"type": "boolean", "default": false},
    "allow_destructive": {"type": "boolean", "default": false},
    "allow_multi_write": {"type": "boolean", "default": false},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "intent", "command"],
        "properties": {
          "id": {"type": "string"},
          "intent": {"type": "string"},
          "command": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}}
            ]
          },
          "prefer_json": {"type": "boolean", "default": true},
          "allow_unknown": {"type": "boolean", "default": false},
          "allow_active": {"type": "boolean", "default": false},
          "allow_budget": {"type": "boolean", "default": false},
          "allow_destructive": {"type": "boolean", "default": false}
        }
      }
    },
    "verification": {"type": "array", "items": {"type": "string"}},
    "rollback_or_stop_rules": {"type": "array", "items": {"type": "string"}}
  }
}
