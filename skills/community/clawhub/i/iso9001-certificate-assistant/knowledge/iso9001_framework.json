    "principles": {
        "principle_1": {
            "en": "Customer focus",
            "zh": "以顾客为关注焦点"
        },
        "principle_2": {
            "en": "Leadership",
            "zh": "领导作用"
        },
        "principle_3": {
            "en": "Engagement of people",
            "zh": "全员参与"
        },
        "principle_4": {
            "en": "Process approach",
            "zh": "过程方法"
        },
        "principle_5": {
            "en": "Improvement",
            "zh": "改进"
        },
        "principle_6": {
            "en": "Evidence-based decision making",
            "zh": "循证决策"
        },
        "principle_7": {
            "en": "Relationship management",
            "zh": "关系管理"
        }
    },
    "pdca_cycle": {
        "plan": {
            "en": "Plan - Establish objectives and processes necessary to deliver results",
            "zh": "策划 - 建立必要的目标和过程以交付结果"
        },
        "do": {
            "en": "Do - Implement the processes",
            "zh": "实施 - 实施过程"
        },
        "check": {
            "en": "Check - Monitor and measure processes and products against policies, objectives and requirements",
            "zh": "检查 - 根据方针、目标和要求监视和测量过程和产品"
        },
        "act": {
            "en": "Act - Take actions to continually improve",
            "zh": "处置 - 采取行动持续改进"
        }
    }
}
