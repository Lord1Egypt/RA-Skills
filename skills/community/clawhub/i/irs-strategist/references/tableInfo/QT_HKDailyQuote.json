    {
        "columnOrderId": 4,
        "columnName": "PrevClosePrice",
        "columnChiName": "昨收盘(元)",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "昨收盘（PrevClosePrice）：当交易所行情源在没有提供昨收盘价，并且当天非停牌，会分几种情况处理，以补充昨收维持涨跌幅和涨跌的计算。其中，新股上市正常不会提供昨收盘价，这时会以发行价做填充，如果是介绍上市等没有明确发行价的情况，为了最大限度接近真实价值，以开盘价填充昨收盘价。分红、送红股、拆股并股等情况港交所会提供除权后的昨收盘，其余情况像涉及实物分配、红利认股证、配股的部分情况，港交所数据源不提供昨收盘价，这部分数据会通过查阅公告等方式，确定一个较为合适的昨收盘价格。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "98.39",
        "remarkNo": "注2"
    },
    {
        "columnOrderId": 5,
        "columnName": "OpenPrice",
        "columnChiName": "开盘价(元)",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "开盘价（OpenPrice）：当交易所行情源在没有提供开盘价，并且当天非停牌，正常是没有成交的情况下，会用当天收盘价进行填充。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "91.22",
        "remarkNo": "注3"
    },
    {
        "columnOrderId": 6,
        "columnName": "HighPrice",
        "columnChiName": "最高价(元)",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "最高价（HighPrice）：当交易所行情源在没有提供最高价，并且当天非停牌，正常是没有成交的情况下，会用当天收盘价进行填充。因交易所的价格生成规则，会有存在最高价<收盘价的情况，会有存在最高价<开盘价的情况。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "91.46",
        "remarkNo": "注4"
    },
    {
        "columnOrderId": 7,
        "columnName": "LowPrice",
        "columnChiName": "最低价(元)",
        "columnType": "decimal(19,4)",
        "isNullable": 1,
        "remark": "最低价（LowPrice）：当交易所行情源在没有提供最低价，并且当天非停牌，正常是没有成交的情况下，会用当天收盘价进行填充。因交易所的价格生成规则，会有存在最低价>收盘价的情况，会有存在最低价>开盘价的情况。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "91.46",
        "remarkNo": "注5"
    },
