                        "7.1.4": {
                            "title": "Process environment",
                            "title_zh": "过程运行环境",
                            "required_documents": ["过程运行环境控制程序"]
                        },
                        "7.1.5": {
                            "title": "Monitoring and measuring resources",
                            "title_zh": "监视和测量资源",
                            "required_documents": ["监视和测量设备控制程序"]
                        },
                        "7.1.6": {
                            "title": "Organizational knowledge",
                            "title_zh": "组织的知识",
                            "required_documents": ["知识管理程序"]
