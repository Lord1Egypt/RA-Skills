{
  "description": "truncation_guard.py L4阈值配置（含组合校验开关）",
  "version": "2.0.0",
  "thresholds": {
    "P1": {
      "min_count": 2,
      "min_operations_coverage": 0.5,
      "check_enabled": true,
      "combo_checks": {
        "operations_coverage": true
      }
    },
    "P5": {
      "min_count": 15,
      "input_ratio": 0.6,
      "check_enabled": true,
      "combo_checks": {
        "module_coverage": true,
        "priority_preservation": true,
        "merge_log_consistency": true
      }
    },
    "P6": {
      "min_count": 10,
      "input_ratio": 0.8,
      "check_enabled": true,
      "combo_checks": {
        "p0_fully_expanded": true
      }
    }
  },
  "defaults": {
    "min_count": 5,
    "input_ratio": 0.5,
    "check_enabled": false
  }
}
