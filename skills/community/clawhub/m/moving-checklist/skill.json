      "Receive personalized countdown timeline + categorized checklist in <20 seconds"
    ],
    "cli": "python scripts/checklist.py --profile '{\"current\":\"整租\",\"new_address\":\"上海浦东\",\"move_date\":\"2025-07-15\",\"distance\":\"同城\",\"household_size\":\"solo\"}'"
  }
