        "required": ["keyword"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "query_hospital",
      "display_name": "医院用药查询",
      "description": "查询主要城市重点医院用药金额排名。返回药品名称、位序、用药金额、同比增减等信息。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "药品名称关键词（如：人血白蛋白）"
          },
          "limit": {
            "type": "integer",
            "description": "最大返回条数（1-200，默认20）",
            "minimum": 1,
