{
  "type": "object",
  "required": [
    "topic"
  ],
  "x-layout": {
    "mode": "contextComposer",
    "rows": 5,
    "primaryField": "topic",
    "advancedLabel": "可选设置",
    "primaryControlFields": [
      "wordCount",
      "tone"
    ],
    "advancedControlFields": [
      "audience",
      "keywords",
      "platform",
      "imageCount",
      "brandRequirements",
      "watermarkMode",
      "watermarkText"
    ]
  },
  "properties": {
    "tone": {
      "enum": [
        "practical",
        "story",
        "expert",
        "lively"
      ],
      "type": "string",
      "title": "语气",
      "default": "practical",
      "enumNames": [
        "实用清晰",
        "故事化",
        "专家型",
        "轻松活泼"
      ],
      "x-options": [
        {
          "icon": "FileText",
          "color": "blue",
          "group": "语气",
          "label": "实用清晰",
          "value": "practical",
          "description": "结构清楚，适合知识型内容"
        },
        {
          "icon": "BookOpen",
          "color": "green",
          "group": "语气",
          "label": "故事化",
          "value": "story",
          "description": "用故事和场景带出观点"
        },
        {
          "icon": "Award",
          "color": "indigo",
          "group": "语气",
          "label": "专家型",
          "value": "expert",
          "description": "更专业，适合建立信任"
        },
        {
          "icon": "Smile",
          "color": "amber",
          "group": "语气",
          "label": "轻松活泼",
          "value": "lively",
          "description": "轻松活泼，更适合社交传播"
        }
      ]
    },
    "topic": {
      "type": "string",
      "title": "主题",
      "x-rows": 5,
      "description": "文章主题、关键词或一句话需求",
      "x-component": "Textarea"
    },
    "audience": {
      "type": "string",
      "title": "目标读者",
      "x-rows": 3,
      "x-component": "Textarea"
    },
    "keywords": {
      "type": "string",
      "title": "关键词",
      "x-rows": 3,
      "x-component": "Textarea"
    },
    "platform": {
      "enum": [
        "all",
        "wechat",
        "xhs",
        "blog",
        "zhihu"
      ],
      "type": "string",
      "title": "发布平台",
      "default": "all",
      "enumNames": [
        "全平台",
        "公众号",
        "小红书",
        "博客",
        "知乎"
      ],
      "x-options": [
        {
          "icon": "Globe",
          "color": "blue",
          "group": "发布平台",
          "label": "全平台",
          "value": "all"
        },
        {
          "icon": "BookOpen",
          "color": "green",
          "group": "发布平台",
          "label": "公众号",
          "value": "wechat",
          "description": "适配公众号图文和长内容发布"
        },
        {
          "icon": "Sparkles",
          "color": "rose",
          "group": "发布平台",
          "label": "小红书",
          "value": "xhs",
          "description": "适配小红书种草、封面和竖图"
        },
        {
          "icon": "FileText",
          "color": "cyan",
          "group": "发布平台",
          "label": "博客",
          "value": "blog",
          "description": "适配博客、官网和 SEO 内容"
        },
        {
          "icon": "PenTool",
          "color": "indigo",
          "group": "发布平台",
          "label": "知乎",
          "value": "zhihu",
          "description": "适配知乎观点和问答表达"
        }
      ]
    },
    "wordCount": {
      "type": "integer",
      "title": "字数",
      "x-unit": "字",
      "default": 1600,
      "maximum": 3000,
      "minimum": 800
    },
    "imageCount": {
      "type": "integer",
      "title": "正文配图数量",
      "x-unit": "张",
      "default": 3,
      "maximum": 5,
      "minimum": 1
    },
    "watermarkMode": {
      "enum": [
        "off",
        "brand",
        "corner",
        "tiled",
        "both"
      ],
      "type": "string",
      "title": "水印",
      "default": "off",
      "enumNames": [
        "不加",
        "品牌轻水印",
        "右下角",
        "平铺",
        "两者"
      ],
      "x-options": [
        {
          "icon": "Shield",
          "color": "slate",
          "group": "水印",
          "label": "不加",
          "value": "off",
          "description": "保持画面干净"
        },
        {
          "icon": "Award",
          "color": "green",
          "group": "水印",
          "label": "品牌轻水印",
          "value": "brand",
          "description": "使用默认品牌署名，适合正式发布"
        },
        {
          "icon": "PenTool",
          "color": "blue",
          "group": "水印",
          "label": "右下角",
          "value": "corner",
          "description": "保留轻量署名"
        },
        {
          "icon": "Layers",
          "color": "amber",
          "group": "水印",
          "label": "平铺",
          "value": "tiled",
          "description": "增加平铺品牌保护"
        },
        {
          "icon": "FileWarning",
          "color": "amber",
          "group": "水印",
          "label": "两者",
          "value": "both",
          "description": "角标和平铺同时露出"
        }
      ]
    },
    "watermarkText": {
      "type": "string",
      "title": "水印内容",
      "default": "ai-skills.ai",
      "maxLength": 80,
      "description": "选择加水印后显示，默认使用 ai-skills.ai，可替换为品牌名、站点或账号。",
      "placeholder": "ai-skills.ai",
      "x-show-when": {
        "field": "watermarkMode",
        "value": "off",
        "operator": "neq"
      }
    },
    "brandRequirements": {
      "type": "string",
      "title": "品牌要求",
      "x-rows": 3,
      "x-component": "Textarea"
    }
  },
  "x-profile-context": true
}
