{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "P3 Risk Identification Output (V3.2.7)",
  "type": "object",
  "required": [
    "risk_points"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "requirement_id": {
      "type": "string"
    },
    "risk_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "source_scenario": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "likelihood": {
            "type": "string"
          },
          "pci_required": {
            "type": "boolean"
          }
        }
      }
    }
  }
}