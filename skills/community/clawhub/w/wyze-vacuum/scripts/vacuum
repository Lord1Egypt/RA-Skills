#!/usr/bin/env node
/*
 * vacuum — check and control a Wyze robot vacuum (status, start, pause, dock).
 * Wraps wyze-node, reusing the cached login token (shared with the wyze skill).
 * Config via env: WYZE_NODE_DIR, WYZE_ENV, WYZE_TOKEN_DIR (see SKILL.md).
 */
const fs = require('fs');
const os = require('os');
const path = require('path');
const home = os.homedir();
const exists = p => { try { fs.accessSync(p); return true; } catch { return false; } };
function die(m) { console.error('error: ' + m); process.exit(1); }

const NODE_DIR = process.env.WYZE_NODE_DIR || path.join(home, 'code', 'wyze-node');
const ENV = process.env.WYZE_ENV || path.join(home, '.openclaw', 'secrets', 'wyze.env');
const TOKEN_DIR = process.env.WYZE_TOKEN_DIR || (exists(NODE_DIR) ? NODE_DIR : path.join(home, '.openclaw', 'wyze'));
const SKILL_DIR = path.join(__dirname, '..');

if (exists(ENV)) {
  for (const line of fs.readFileSync(ENV, 'utf8').split('\n')) {
    const m = line.match(/^\s*([A-Z_]+)\s*=\s*(.*)\s*$/);
    if (m && !process.env[m[1]]) process.env[m[1]] = m[2];
  }
}
try { fs.mkdirSync(TOKEN_DIR, { recursive: true }); process.chdir(TOKEN_DIR); }
catch { die('cannot use token dir ' + TOKEN_DIR); }

let Wyze;
for (const cand of ['wyze-node', path.join(SKILL_DIR, 'node_modules', 'wyze-node'), path.join(NODE_DIR, 'src', 'index.js')]) {
  try { Wyze = require(cand); break; } catch {}
}
if (!Wyze) die('wyze-node not found — run: npm install --prefix "' + path.join(SKILL_DIR, 'scripts') + '" wyze-node');

let _w;
function client() { return _w || (_w = new Wyze({ username: process.env.WYZE_EMAIL, keyId: process.env.WYZE_KEY_ID, apiKey: process.env.WYZE_API_KEY })); }
const isVac = d => d.product_type === 'JA_RO2' || d.product_model === 'JA_RO2' || /vacuum/i.test(d.product_type || '');
async function vacuums() { return (await client().getDeviceList()).filter(isVac); }

async function pick(query) {
  const list = await vacuums();
  if (!list.length) die('no Wyze vacuum found on this account');
  if (!query) { if (list.length === 1) return list[0]; die('which vacuum? ' + list.map(d => (d.nickname || '').trim()).join(', ')); }
  const s = query.toLowerCase().trim();
  const hits = list.filter(d => (d.nickname || '').toLowerCase().includes(s));
  if (!hits.length) die('no vacuum matching "' + query + '". Try: status');
  if (hits.length > 1) die('"' + query + '" matches ' + hits.length + ' vacuums: ' + hits.map(d => (d.nickname || '').trim()).join(', '));
  return hits[0];
}

// derive a human status from the venus heartBeat
function describe(hb, ef) {
  if (!hb) return 'unknown';
  if (hb.charge_state === 1) return 'docked (charging)';
  if (hb.mode === 0) return 'idle';
  return 'cleaning';
}

(async () => {
  const [cmd, ...rest] = process.argv.slice(2);
  const w = client();

  if (!cmd || cmd === 'status') {
    const vac = await pick(rest[0]);
    const name = (vac.nickname || '').trim();
    const res = await w.getVacuumStatus(vac);
    const data = (res && res.data) || {};
    const hb = data.heartBeat || {};
    const ef = data.eventFlag || {};
    const online = ef.iot_state ? ef.iot_state : (hb.charge_state != null ? 'connected' : 'unknown');
    const bat = hb.battery != null ? hb.battery : ef.power_state;
    console.log(`${name}: ${describe(hb, ef)}`);
    if (bat != null) console.log(`Battery: ${bat}%`);
    if (hb.clean_time != null) console.log(`Last clean: ${hb.clean_time} min${hb.clean_size != null ? `, ${hb.clean_size} units` : ''}`);
    console.log(`Connection: ${online}`);
    return;
  }

  if (cmd === 'start' || cmd === 'pause' || cmd === 'dock') {
    const vac = await pick(rest[0]);
    const name = (vac.nickname || '').trim();
    if (cmd === 'start') await w.startVacuum(vac);
    else if (cmd === 'pause') await w.pauseVacuum(vac);
    else await w.dockVacuum(vac);
    console.log(`${cmd}: ${name}`);
    return;
  }

  die('unknown command "' + cmd + '". Commands: status [name], start [name], pause [name], dock [name]');
})().catch(e => die((e && e.message) || String(e)));
