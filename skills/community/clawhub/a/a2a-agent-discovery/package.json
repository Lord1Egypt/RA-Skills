{
  "name": "itinai-a2a-catalog-mcp",
  "version": "0.1.4",
  "description": "MCP server for ITINAI A2A discovery, service requests, Agent Card inspection, and manifest submission.",
  "type": "module",
  "bin": {
    "itinai-a2a-catalog-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples",
    "scripts/autocheck-skill.mjs"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "autocheck": "node scripts/autocheck-skill.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "a2a",
    "agent-card",
    "itinai",
    "ai-agent-catalog"
  ],
  "license": "MIT"
}
