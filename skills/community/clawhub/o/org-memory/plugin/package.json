  "type": "module",
  "description": "Agent-memory extension for org-cli: persists agent knowledge and daily notes to an org workspace, overriding memory-wiki.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DCPRevere/org-cli.git",
    "directory": "integrations/openclaw/org-memory/plugin"
  },
  "files": [
