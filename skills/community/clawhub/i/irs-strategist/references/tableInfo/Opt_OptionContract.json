    {
        "columnOrderId": 6,
        "columnName": "ULAInnerCode",
        "columnChiName": "标的内部编码",
        "columnType": "int",
        "isNullable": 1,
        "remark": "标的内部编码(ULAInnerCode)：当品种类别(ULAType) in（1,2，4）时，与“证券主表（SecuMain）”中的“证券内部编码（InnerCode）”关联，得到期权标的证券的基本信息等；当品种类别(ULAType)=3,即为期货期权时，与“期货合约主表（Fut_ContractMain）”中的“合约内部编码（ContractInnerCode）”关联，得到期权标的期货合约的基本信息等；与“期货交易日行情（Fut_DailyQuote）”中的“合约内部编码（InnerCode）”关联，得到期权标的期货合约的每日行情。当品种类别(ULAType)=4,即为股指期权时，与“指数基本情况（LC_IndexBasicInfo）”中的“指数内部编码（IndexCode）”关联，得到期权标的股指的基本信息等；与“指数行情（QT_IndexQuote）”中的“证券内部编码（InnerCode）”关联，得到期权标的股指的每日行情。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "100.0",
        "remarkNo": "注1"
    },
