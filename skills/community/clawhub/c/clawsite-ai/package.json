{
  "name": "clawsite",
  "version": "0.1.0",
  "description": "Agent-first static website hosting microservice (clawsite.ai)",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1007.0",
    "@aws-sdk/client-dynamodb": "^3.1007.0",
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/lib-dynamodb": "^3.1007.0",
    "ulid": "^3.0.2",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.4.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yazl": "^3.3.1"
