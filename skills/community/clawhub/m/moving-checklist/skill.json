    { "step": 5, "name": "Budget Estimation", "input": "Moving profile", "output": "Cost breakdown" },
    { "step": 6, "name": "Generate Printable Handbook", "input": "All outputs", "output": "Complete moving handbook" },
    { "step": 7, "name": "Post-Move Follow-up", "input": "Move complete signal", "output": "Settling checklist" }
  ],
  "firstSuccessPath": {
    "steps": [
      "Say: 我下个月搬家，一室一厅，同城，帮我出个清单",
