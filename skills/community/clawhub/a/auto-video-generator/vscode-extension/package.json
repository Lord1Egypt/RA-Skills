{"name": "auto-video-generator", "displayName": "Auto Video Generator", "description": "Generate demo videos from HTML pages with voice narration. Supports Vue/React components, auto-detects UI frameworks, and creates professional presentation videos.", "version": "3.0.0", "publisher": "avg-team", "engines": {"vscode": "^1.74.0"}, "categories": ["Other", "Visualization"], "keywords": ["video", "demo", "presentation", "screenshot", "automation", "testing"], "activationEvents": ["onCommand:avg.generateVideo", "onCommand:avg.openConfigPanel", "onCommand:avg.detectEnvironment", "onView:avg-config-panel", "onLanguage:html", "onLanguage:vue", "onLanguage:typescriptreact", "onLanguage:javascriptreact"], "main": "./out/extension.js", "contributes": {"commands": [{"command": "avg.generateVideo", "title": "AVG: Generate Demo Video", "category": "Auto Video Generator", "icon": "$(play)"}, {"command": "avg.generateVideoFromURL", "title": "AVG: Generate from URL", "category": "Auto Video Generator"}, {"command": "avg.openConfigPanel", "title": "AVG: Open Configuration Panel", "category": "Auto Video Generator", "icon": "$(gear)"}, {"command": "avg.detectEnvironment", "title": "AVG: Detect Environment", "category": "Auto Video Generator", "icon": "$(search)"}, {"command": "avg.showPerformanceDashboard", "title": "AVG: Show Performance Dashboard", "category": "Auto Video Generator"}, {"command": "avg.exportConfigTemplate", "title": "AVG: Export Config Template", "category": "Auto Video Generator"}], "menus": ["editor/context": [{"when": "resourceExtname == .html || resourceExtname == .vue || resourceExtname == .tsx || resourceExtname == .jsx", "command": "avg.generateVideo", "group": "navigation@1"}], "editor/title": [{"when": "resourceExtname == .html || resourceExtname == .vue", "command": "avg.generateVideo", "group": "navigation@1"}], "view/title": [{"command": "avg.openConfigPanel", "when": "view == avg-config-panel", "group": "navigation"}]], "viewsContainers": {"activitybar": [{"id": "avg-sidebar", "title": "Video Generator", "icon": "$(device-camera-video)"}]}, "views": {"avg-sidebar": [{"type": "webview", "id": "avg-config-panel", "name": "Configuration", "icon": "$(settings-gear)", "contextualTitle": "AVG Config"}]}, "configuration": {"title": "Auto Video Generator", "properties": {"avg.browser.headless": {"type": "boolean", "default": false, "description": "Run browser in headless mode"}, "avg.video.fps": {"type": "number", "default": 4, "minimum": 1, "maximum": 30, "description": "Video frames per second"}, "avg.audio.voice": {"type": "string", "default": "zh-CN-YunxiNeural", "enum": ["zh-CN-YunxiNeural", "zh-CN-XiaoxiaoNeural", "en-US-GuyNeural", "en-US-JennyNeural"], "description": "TTS voice selection"}, "avg.outputDir": {"type": "string", "default": "./video_output", "description": "Output directory for generated videos"}}}, "keybindings": [{"command": "avg.generateVideo", "key": "ctrl+shift+v", "mac": "cmd+shift+v", "when": "editorTextFocus && (resourceExtname == .html || resourceExtname == .vue)"}, {"command": "avg.openConfigPanel", "key": "ctrl+shift+g", "mac": "cmd+shift+g", "when": "!avg.configPanelActive"}], "icons": {"avg-icon": {"description": "Auto Video Generator icon", "default": {"font": "device-camera-video"}}}}, "scripts": {"vscode:prepublish": "npm run compile", "compile": "tsc -p ./", "watch": "tsc -watch -p ./", "pretest": "npm run compile && npm run lint", "lint": "eslint src --ext ts", "test": "node ./out/test/runTest.js"}, "devDependencies": {"@types/vscode": "^1.74.0", "@types/node": "^18.x", "@types/glob": "^8.x", "@typescript-eslint/eslint-plugin": "^6.x", "@typescript-eslint/parser": "^6.x", "@vscode/test-electron": "^2.3.0", "@vscode/vsce": "^2.22.0", "eslint": "^8.x", "glob": "^10.x", "typescript": "^5.x"}, "repository": {"type": "git", "url": "https://github.com/your-org/auto-video-generator.git"}, "license": "MIT", "bugs": {"url": "https://github.com/your-org/auto-video-generator/issues"}}