      {"function": "input() (Python 2)", "risk": "高", "cwe": "CWE-95", "reason": "Python 2 中 input() = eval(raw_input())", "alternative": "raw_input() (Python 2) 或 input() (Python 3)"},
      {"function": "hashlib.md5() (密码)", "risk": "中", "cwe": "CWE-327", "reason": "MD5 已被破解，不可用于密码存储", "alternative": "bcrypt / scrypt / argon2"},
      {"function": "hashlib.sha1() (密码)", "risk": "中", "cwe": "CWE-327", "reason": "SHA1 存在碰撞攻击", "alternative": "SHA-256 或 bcrypt"},
      {"function": "random.random() (安全)", "risk": "中", "cwe": "CWE-330", "reason": "伪随机数生成器，不可用于安全场景", "alternative": "secrets.token_hex() 或 os.urandom()"},
      {"function": "xml.etree.ElementTree.parse() (默认)", "risk": "高", "cwe": "CWE-611", "reason": "默认解析 XML 外部实体", "alternative": "defusedxml 或 resolve_entities=False"},
      {"function": "shelve.open()", "risk": "高", "cwe": "CWE-502", "reason": "内部使用 pickle", "alternative": "JSON 文件或 SQLite"},
      {"function": "tarfile.extractall()", "risk": "中", "cwe": "CWE-22", "reason": "可能触发 Zip Slip", "alternative": "逐个检查成员路径后再解压"}
    ],
    "javascript": [
