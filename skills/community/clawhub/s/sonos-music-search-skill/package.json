{
  "name": "sonos-music-search-skill",
  "version": "1.1.1",
  "description": "Sonos skill that uses Brave Search to find and play music",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "audit": "skill-audit . --report audit-report.md",
    "format": "prettier --write \"**/*.{js,md}\"",
    "format:check": "prettier --check \"**/*.{js,md}\""
  },
  "dependencies": {
    "brave-search": "^0.9.0",
    "sonos": "^1.15.0"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "@clawhub/skill-audit": "^2.1.0"
  },
  "keywords": ["sonos", "brave-search", "clawhub-skill"],
  "author": "sonos-music-search-skill contributors",
  "license": "MIT"
}
