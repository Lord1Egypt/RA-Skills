{
  "name": "drug-matching-skill",
  "display_name": "药撮合品种综合查询",
  "description": "药撮合品种综合查询技能。根据客户需求（剂型、产品名称、适应症、治疗领域、医保属性等）从转让目录中筛选匹配品种，同时支持查询药品医保状态、基药状态、产量数据、一致性评价、医院用药排名、国际认证等。内嵌药品说明书查询技能。",
  "version": "2.3.0",
  "author": "药撮合",
  "license": "MIT",
  "repository": "https://gitee.com/drug-matching/tool-library-for-drug-matching",
  "category": "药品信息查询",
  "keywords": [
    "药撮合",
    "批文转让",
    "药品批文",
    "批文买卖",
    "化药转让",
    "中成药转让",
    "医保查询",
    "基药查询",
    "一致性评价",
    "药品产量",
    "医院用药",
    "国际认证",
    "MAH",
    "B证",
    "仿制药",
    "药品交易",
    "品种查询",
    "转让目录",
    "药品信息"
  ],
  "mcp_server": {
    "transport": "streamable-http",
    "url": "http://120.53.229.6:8900/mcp"
  },
  "tools": [
    {
      "name": "query_transfer",
      "display_name": "转让目录查询",
      "description": "从中成药/化药转让目录中筛选品种。支持按剂型、适应症、医保、基药、OTC、集采、治疗领域等条件组合查询。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "类别": {
            "type": "string",
            "description": "品种类别：中成药/化药/全部（默认全部）",
            "enum": ["中成药", "化药", "全部"]
          },
          "剂型": {
            "type": "string",
            "description": "剂型关键词（如：片剂、胶囊、注射剂），模糊匹配"
          },
          "产品名称": {
            "type": "string",
            "description": "品种/产品名称关键词"
          },
          "适应症": {
            "type": "string",
            "description": "适应症关键词"
          },
          "治疗领域": {
            "type": "string",
            "description": "治疗领域（仅化药，如：心血管、消化系统）"
          },
          "医保": {
            "type": "string",
            "description": "医保属性：医保/非医保"
          },
          "基药": {
            "type": "string",
            "description": "基药属性：基药/非基药"
          },
          "OTC": {
            "type": "string",
            "description": "OTC属性：OTC/非OTC"
          },
          "集采": {
            "type": "string",
            "description": "集采属性（仅化药）：集采/否"
          },
          "limit": {
            "type": "integer",
            "description": "最大返回条数（1-200，默认20）",
            "minimum": 1,
            "maximum": 200,
            "default": 20
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "query_insurance",
      "display_name": "医保查询",
      "description": "查询药品是否纳入医保目录及甲/乙类。返回药品名称、部类（西药/中成药/谈判药）、甲乙类、剂型、分类等信息。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "药品名称关键词（如：奥美拉唑）"
          },
          "limit": {
            "type": "integer",
            "description": "最大返回条数（1-200，默认20）",
            "minimum": 1,
            "maximum": 200,
            "default": 20
          }
        },
        "required": ["keyword"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "query_essential",
      "display_name": "基药查询",
      "description": "查询药品是否国家基本药物（2018版）。返回品种名称、部类、分类、剂型规格等信息。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
