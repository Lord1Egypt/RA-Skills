{
  "name": "ChoiGPT Binance Trading Bot",
  "version": "1.0.0",
  "description": "Sweepzone V1 전략 기반 바이낸스 선물 자동매매 및 분석 봇",
  "author": "ALEXCHOI21",
  "repository": "https://github.com/ALEXCHOI21/binance_auto",
  "entrypoint": "src/main.py",
  "configurations": [
    {
      "key": "BINANCE_API_KEY",
      "type": "string",
      "description": "바이낸스 API 키",
      "required": true
    },
    {
      "key": "BINANCE_SECRET_KEY",
      "type": "string",
      "description": "바이낸스 시크릿 키",
      "required": true
    },
    {
      "key": "TELEGRAM_BOT_TOKEN",
      "type": "string",
      "description": "텔레그램 봇 토큰",
      "required": true
    },
    {
      "key": "TELEGRAM_CHAT_ID",
      "type": "string",
      "description": "텔레그램 채팅 ID",
      "required": true
    }
  ]
}
