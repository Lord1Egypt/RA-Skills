{
  "name": "成均内容安全",
  "slug": "chengjun-content-security",
  "version": "1.0.0",
  "description": "通过调用成均平台的内容安全接口，检测文本中的敏感信息、语法错误、标点符号问题等，保障内容合规。",
  "author": "成均",
  "license": "MIT",
  "platform": {
    "always": false,
    "disable-model-invocation": false
  },
  "install": {
    "type": "instruction-only",
    "instructions": [
      "pip install -r requirements.txt",
      "设置环境变量: export CHENGJUN_API_KEY='your_api_key_here'",
      "获取API密钥: 访问开放平台注册页面获取"
    ]
  },
  "environment": {
    "variables": [
      {
        "name": "CHENGJUN_API_KEY",
        "description": "成均平台API密钥",
        "required": true
      }
    ]
  },
  "tools": [
    {
      "name": "check_content",
      "description": "检测文本内容中的敏感信息、语法错误等问题",
      "parameters": {
        "text": {
          "type": "string",
          "description": "待检测的文本内容",
          "required": true
        },
        "api_key": {
          "type": "string",
          "description": "API密钥（可选，默认从环境变量读取）",
          "required": false
        }
      }
    }
  ]
}
