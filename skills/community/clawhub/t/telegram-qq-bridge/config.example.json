{
  "name": "telegram-qq-bridge",
  "version": "1.0.0",
  "description": "Telegram → QQ 自动转发插件",
  "config": {
    "enabled": true,
    "qqTarget": "qqbot:c2c:YOUR_OPENID_HERE",
    "qqAccount": "your_qq_account_name",
    "pollInterval": 2000,
    "sessionFile": "~/.openclaw/agents/stockworker/sessions/YOUR_SESSION.jsonl"
  },
  "environment": {
    "QQ_TARGET": "qqbot:c2c:YOUR_OPENID_HERE",
    "QQ_ACCOUNT": "your_qq_account_name",
    "POLL_INTERVAL": "2000",
    "TELEGRAM_QQ_SESSION_FILE": "~/.openclaw/agents/stockworker/sessions/YOUR_SESSION.jsonl"
  }
}
