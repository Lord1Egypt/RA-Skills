{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "抖音评论获取 - 命令行入参",
    "description": "抖音获取作品评论, 命令行参数入参Schema详解",
    "required": [
        "url"
    ],
    "properties": {
        "url": {
            "type": "string",
            "description": "抖音作品URL 或 作品aweme_id"
        },
        "limit": {
            "type": "number",
            "description": "获取评论数量",
            "minimum": 1,
            "maximum": 10000,
            "default": 10
        }
    },
    "additionalProperties": false
}