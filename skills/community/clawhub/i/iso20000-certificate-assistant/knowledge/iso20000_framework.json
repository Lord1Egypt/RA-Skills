  "high_voltage_lines": [
    {
      "name": "Change grading & timing",
      "chinese_name": "变更分级与时效",
      "description": "Check if 'general change' vs 'major change' is distinguished; major changes must execute during 00:00-06:00 window.",
      "chinese_description": "检查是否区分'一般变更'与'重大变更'；重大变更必须在凌晨00:00-06:00窗口执行。",
      "related_clauses": ["8.5.1", "8.2.3"]
    },
    {
      "name": "Incident & fault handling",
      "chinese_name": "事件与故障处理",
      "description": "Define Incident = 'fault'; establish 1-3 level grading; implement 'restore service first, then find root cause' principle.",
      "chinese_description": "将Incident定义为'故障'；建立1-3级分级标准；贯彻'先恢复业务，后查找根因'的原则。",
      "related_clauses": ["8.4.1", "8.4.2"]
    },
    {
      "name": "RACI responsibilities",
      "chinese_name": "归口管理职责",
      "description": "Clear segregation of system owner, service quality supervision, and procurement/comprehensive departments.",
      "chinese_description": "明确体系归口部门、服务质量监督部门、采购/综合部门的三方分离。",
      "related_clauses": ["5.3", "8.3.1", "8.3.3"]
    },
    {
      "name": "Supplier risk management",
      "chinese_name": "供应商风险管理",
      "description": "Prohibit single supplier from fully responsible for single service/component.",
      "chinese_description": "提出'禁止单一供应商全权负责单一服务/组件'的要求。",
      "related_clauses": ["8.2.3", "8.3.3"]
    }
  ],
