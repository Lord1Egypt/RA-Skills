                "7.3": {
                    "title": "Awareness",
                    "title_zh": "意识",
                    "required_documents": ["意识管理程序"]
                },
                "7.4": {
                    "title": "Communication",
                    "title_zh": "沟通",
                    "required_documents": ["沟通管理程序"]
                },
                "7.5": {
                    "title": "Documented information",
                    "title_zh": "成文信息",
                    "required_documents": ["文件控制程序", "记录控制程序"]
                }
            }
        },
        "8": {
            "title": "Operation",
            "title_zh": "运行",
            "subclauses": {
                "8.1": {
                    "title": "Operational planning and control",
                    "title_zh": "运行的策划和控制",
                    "required_documents": ["运营策划和控制程序"]
