        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "query_production",
      "display_name": "产量查询",
      "description": "查询品种2020年产量数据。返回产品名称、企业名称、产量、规格等信息。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "产品名称关键词（如：奥美拉唑）"
