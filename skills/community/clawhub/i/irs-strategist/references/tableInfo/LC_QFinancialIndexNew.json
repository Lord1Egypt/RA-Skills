        "columnOrderId": 28,
        "columnName": "ROIC",
        "columnChiName": "投入资本回报率(%)",
        "columnType": "decimal(18,4)",
        "isNullable": 1,
        "remark": "投入资本回报率(%)(ROIC)=息税前利润*（1-有效税率）*2/（期初全部投入资本+期末全部投入资本））*100%， 其中，“息税前利润”计算方法见EBIT[息税前利润(元)]；有效税率=所得税/利润总额，否则赋值为0计算；全部投入资本=股东权益（含少数股东权益）+带息债务=股东权益（含少数股东权益）+（负债合计-无息流动负债-无息非流动负债），无息流动负债=应付帐款及应付票据+预收款项+应付职工薪酬+应交税费+其他应付款合计+预提费用+递延收益+合同负债+其他流动负债+衍生金融负债（其中：其他应付款合计包括其他应付款、应付股利、应付利息）；无息非流动负债=非流动负债合计-长期借款-应付债券-租赁负债。金融类企业不计算。",
        "slaveFieldId": 0,
        "isEffective": true,
        "tableVersion": null,
        "valueRate": "94.02",
        "remarkNo": "注24"
    },
