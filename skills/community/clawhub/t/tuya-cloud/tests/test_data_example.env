# Copy this file to test_data.env and fill in your device IDs
SENSOR_DEVICE_ID=your_sensor_device_id
WATER_VALVE_DEVICE_ID=your_water_valve_device_id
WATER_VALVE_GATEWAY_ID=your_gateway_device_id

# Local LAN connection (get IP from router, local_key from Tuya cloud device detail)
SENSOR_IP=192.168.1.x
SENSOR_LOCAL_KEY=your_sensor_local_key
SENSOR_VERSION=3.3

WATER_VALVE_IP=192.168.1.x
WATER_VALVE_LOCAL_KEY=your_water_valve_local_key
WATER_VALVE_VERSION=3.3
