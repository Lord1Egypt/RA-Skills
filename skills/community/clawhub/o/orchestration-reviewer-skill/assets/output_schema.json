{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Result",
  "type": "object",
  "required": ["review_id", "overall_decision", "scorecard", "issues"],
  "properties": {
    "review_id": {"type": "string"},
    "overall_decision": {"type": "string", "enum": ["pass", "conditional_pass", "reject", "insufficient_information"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "review_summary": {"type": "string"},
    "scorecard": {
      "type": "object",
      "properties": {
        "goal_alignment": {"type": "number"},
        "topology_soundness": {"type": "number"},
        "skill_binding": {"type": "number"},
        "scope_safety": {"type": "number"},
        "executability": {"type": "number"},
        "efficiency_complexity": {"type": "number"},
        "risk_governance": {"type": "number"}
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "severity": {"type": "string", "enum": ["critical", "major", "minor", "info"]},
          "description": {"type": "string"},
          "dimension": {"type": "string"},
          "suggestion": {"type": "string"}
        }
      }
    },
    "suggested_actions": {"type": "array", "items": {"type": "string"}},
    "validation_report": {
      "type": "object",
      "properties": {
        "schema_valid": {"type": "boolean"},
        "dag_valid": {"type": "boolean"},
        "skills_bound": {"type": "boolean"},
        "scope_valid": {"type": "boolean"}
      }
    },
    "revised_plan_ir": {"type": "object"},
    "diff_report": {"type": "object"},
    "revision_summary": {"type": "string"}
  }
}
