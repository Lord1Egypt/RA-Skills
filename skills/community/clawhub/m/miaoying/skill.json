{
  "name": "miaoying",
  "version": "1.0.4",
  "description": "秒应 CLI 工具 - 创建统计、投票、预约、考试、查查并导出数据",
  "author": "积致科技（北京）有限公司",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/creatorkuang/miaoying-cli-skill.git"
  },
  "homepage": "https://github.com/creatorkuang/miaoying-cli-skill#readme",
  "bugs": {
    "url": "https://github.com/creatorkuang/miaoying-cli-skill/issues"
  },

  "install": {
    "command": "npm install --ignore-scripts",
    "alternative_command": "npm ci --ignore-scripts",
    "description": "安装 Node.js 依赖（axios, form-data, xlsx, qrcode）",
    "requires_internet": true,
    "writes_to": [
      "node_modules/",
      "package-lock.json"
    ],
    "verify_integrity": "npm audit --audit-level=moderate"
  },

  "binaries": {
    "required": [
      {
        "name": "node",
        "version": ">=16.0.0",
        "description": "Node.js 运行时"
      },
      {
        "name": "npm",
        "description": "Node.js 包管理器（用于安装依赖）"
      }
    ]
  },

  "credentials": {
    "required": [
      {
        "name": "MIAOYING_API_KEY",
        "type": "api_key",
        "description": "秒应 OpenAPI 密钥，用于创建活动、生成二维码等操作",
        "required": true,
        "obtain_command": "node ./bin/miaoying.js login",
        "permissions": [
          "creator:create",
          "creator:read",
          "creator:export"
        ],
        "storage": {
          "recommended": "environment_variable",
          "fallback": "config_file",
          "config_path": "~/.miaoying/config.json",
          "security_note": "推荐使用环境变量存储，避免在聊天会话中直接粘贴长期密钥"
        }
      }
    ]
  },

  "env": {
    "MIAOYING_API_KEY": {
      "description": "秒应 API 密钥（必需 - 未配置将无法使用本技能）",
      "required": true,
      "security_note": "推荐使用环境变量存储，避免在聊天会话中直接粘贴"
    }
  },

  "file_access": {
    "read": [
      {
        "path": "~/.miaoying/config.json",
        "description": "读取本地存储的 API 密钥配置"
      },
      {
        "path": "./qrcodes/*.png",
        "description": "读取生成的二维码图片"
      },
      {
        "path": "./qrcodes/*.jpeg",
        "description": "读取生成的二维码图片"
      },
      {
        "path": "./src/**/*.js",
        "description": "CLI 源代码（本地直接使用）"
      },
      {
        "path": "./bin/miaoying.js",
        "description": "CLI 入口文件"
      },
      {
        "path": "./package.json",
        "description": "依赖配置文件"
      }
    ],
    "write": [
      {
        "path": "~/.miaoying/config.json",
        "description": "存储 API 密钥配置（可选）"
      },
      {
        "path": "./qrcodes/*.png",
        "description": "保存生成的二维码图片"
      },
      {
        "path": "./qrcodes/*.jpeg",
        "description": "保存生成的二维码图片"
      },
      {
        "path": "./node_modules/**",
        "description": "npm 依赖安装目录"
      },
      {
        "path": "~/.miaoying/caches/**",
        "description": "下载文件缓存目录"
      }
    ]
  },

  "network": {
    "allowed_hosts": [
      {
        "host": "miaoying.hui51.cn",
        "description": "秒应用户管理后台（获取 API Key、管理账户）",
        "endpoints": ["/apikey"]
      },
      {
        "host": "www.aiphoto8.cn",
        "description": "秒应 OpenAPI 服务器（实际 API 调用）",
        "endpoints": [
          "/api/openapi/graphql",
          "/api/openapi/creator/qrcode",
          "/api/openapi/oss-sign",
          "/api/openapi/prompts",
          "/api/openapi/apikeys/self/deactivate",
          "/weapi/weixin/qrcodeApiKeyLogin",
          "/weapi/weixin/getUserWithSceneId/{sceneId}"
        ]
      },
      {
        "host": "cdn.hui51.cn",
        "description": "CDN 域名，用于下载文件和图片",
        "endpoints": ["/uploads/*"]
      },
      {
        "host": "hui51.oss-cn-beijing.aliyuncs.com",
        "description": "阿里云 OSS 存储，用于文件下载",
        "endpoints": ["/*"]
      }
    ],
    "security": {
      "ssrf_protection": true,
      "domain_allowlist": [
        "cdn.hui51.cn",
        "hui51.oss-cn-beijing.aliyuncs.com"
      ],
      "max_download_size_mb": 20,
      "request_timeout_seconds": 30,
      "redirects_allowed": false
    }
  },

  "dependencies": {
    "safe_dependencies": [
      {
        "name": "axios",
        "version": ">=1.0.0",
        "purpose": "HTTP 客户端，用于调用秒应 API",
        "npm_url": "https://www.npmjs.com/package/axios"
      },
      {
        "name": "form-data",
        "version": ">=4.0.0",
        "purpose": "处理 multipart/form-data 文件上传",
        "npm_url": "https://www.npmjs.com/package/form-data"
      },
      {
        "name": "xlsx",
        "version": ">=0.18.0",
        "purpose": "Excel 文件解析，用于数据导出",
        "npm_url": "https://www.npmjs.com/package/xlsx"
      },
      {
        "name": "qrcode",
        "version": ">=1.5.0",
        "purpose": "二维码图片生成，用于扫码登录时将微信链接编码为二维码图片",
        "npm_url": "https://www.npmjs.com/package/qrcode"
      }
    ],
    "security_notes": [
      "所有依赖均为知名 npm 包，无恶意代码风险",
      "package.json 中无 postinstall/preinstall 生命周期脚本",
      "使用 --ignore-scripts 禁止执行任何包脚本",
      "建议使用 npm ci（而非 npm install）以确保依赖版本锁定"
    ]
  },

  "capabilities": {
    "can_create": [
      "统计/打卡/接龙活动",
      "投票活动",
      "预约活动",
      "考试/测验",
      "查查（数据查询表格）"
    ],
    "can_export": [
      "xlsx 格式数据导出",
      "jsonl 格式数据导出"
    ],
    "can_generate": [
      "二维码图片"
    ],
    "can_download": [
      "OSS 文件下载（图片、附件）"
    ],
    "can_login": [
      "微信扫码获取 API Key"
    ]
  },

  "security": {
    "credential_handling": {
      "storage_methods": ["environment_variable", "config_file"],
      "config_file_gitignore_recommendation": true,
      "no_hardcoded_credentials": true
    },
    "network_security": {
      "https_only": true,
      "ssl_verification": true,
      "domain_allowlist_enforced": true
    },
    "file_security": {
      "path_traversal_protection": true,
      "download_size_limit": true,
      "cache_directory_isolated": true
    }
  }
}
