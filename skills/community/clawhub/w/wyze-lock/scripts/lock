#!/usr/bin/env node
/*
 * lock — check and control Wyze locks (status, lock, unlock).
 * Wraps wyze-node, reusing the cached login token (shared with the wyze skill).
 * Config via env: WYZE_NODE_DIR, WYZE_ENV, WYZE_TOKEN_DIR (see SKILL.md).
 * SAFETY: `unlock` opens a physical door — callers must confirm first.
 */
const fs = require('fs');
const os = require('os');
const path = require('path');
const home = os.homedir();
const exists = p => { try { fs.accessSync(p); return true; } catch { return false; } };
function die(m) { console.error('error: ' + m); process.exit(1); }

const NODE_DIR = process.env.WYZE_NODE_DIR || path.join(home, 'code', 'wyze-node');
const ENV = process.env.WYZE_ENV || path.join(home, '.openclaw', 'secrets', 'wyze.env');
const TOKEN_DIR = process.env.WYZE_TOKEN_DIR || (exists(NODE_DIR) ? NODE_DIR : path.join(home, '.openclaw', 'wyze'));
const SKILL_DIR = path.join(__dirname, '..');

if (exists(ENV)) {
  for (const line of fs.readFileSync(ENV, 'utf8').split('\n')) {
    const m = line.match(/^\s*([A-Z_]+)\s*=\s*(.*)\s*$/);
    if (m && !process.env[m[1]]) process.env[m[1]] = m[2];
  }
}
try { fs.mkdirSync(TOKEN_DIR, { recursive: true }); process.chdir(TOKEN_DIR); }
catch { die('cannot use token dir ' + TOKEN_DIR); }

let Wyze;
for (const cand of ['wyze-node', path.join(SKILL_DIR, 'node_modules', 'wyze-node'), path.join(NODE_DIR, 'src', 'index.js')]) {
  try { Wyze = require(cand); break; } catch {}
}
if (!Wyze) die('wyze-node not found — run: npm install --prefix "' + path.join(SKILL_DIR, 'scripts') + '" wyze-node');

let _w;
function client() { return _w || (_w = new Wyze({ username: process.env.WYZE_EMAIL, keyId: process.env.WYZE_KEY_ID, apiKey: process.env.WYZE_API_KEY })); }
const isLock = d => d.product_type === 'Lock';
async function locks() { return (await client().getDeviceList()).filter(isLock); }

async function pick(query) {
  const list = await locks();
  if (!list.length) die('no Wyze lock found on this account');
  if (!query) { if (list.length === 1) return list[0]; die('which lock? ' + list.map(d => (d.nickname || '').trim()).join(', ')); }
  const s = query.toLowerCase().trim();
  const hits = list.filter(d => (d.nickname || '').toLowerCase().includes(s));
  if (!hits.length) die('no lock matching "' + query + '". Try: status');
  if (hits.length > 1) die('"' + query + '" matches ' + hits.length + ' locks: ' + hits.map(d => (d.nickname || '').trim()).join(', '));
  return hits[0];
}

// hardlock: 1 = locked, 2 = unlocked
const lockState = s => s === 1 ? 'locked' : s === 2 ? 'unlocked' : 'unknown';

async function statusOf(lock) {
  const info = await client().getLockInfo(lock);
  const dev = (info && info.device) || info || {};
  const ls = dev.locker_status || {};
  return { name: (lock.nickname || dev.nickname || '').trim(), state: lockState(ls.hardlock), battery: dev.power, online: dev.onoff_line === 1 };
}

(async () => {
  const [cmd, ...rest] = process.argv.slice(2);
  const w = client();

  if (!cmd || cmd === 'status' || cmd === 'list') {
    const list = await locks();
    if (!list.length) die('no Wyze lock found on this account');
    const targets = rest[0] && cmd !== 'list' ? [await pick(rest[0])] : list;
    for (const lock of targets) {
      const s = await statusOf(lock);
      const bat = s.battery != null ? `  battery ${s.battery}%` : '';
      console.log(`${s.state.padEnd(8)} ${s.name}${bat}${s.online ? '' : '  (offline)'}`);
    }
    return;
  }

  if (cmd === 'lock' || cmd === 'unlock') {
    const lock = await pick(rest[0]);
    const name = (lock.nickname || '').trim();
    if (cmd === 'lock') await w.lockDoor(lock); else await w.unlockDoor(lock);
    // confirm the resulting state
    let after = '';
    try { after = ' → ' + (await statusOf(lock)).state; } catch {}
    console.log(`${cmd}: ${name}${after}`);
    return;
  }

  die('unknown command "' + cmd + '". Commands: status [name], lock <name>, unlock <name>');
})().catch(e => die((e && e.message) || String(e)));
