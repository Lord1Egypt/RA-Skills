{
  "name": "bilingual-humanizer",
  "version": "3.2.0",
  "description": "Bilingual AI Humanizer - detect and remove AI writing patterns in Spanish and English. 49 pattern detectors (29 EN + 20 ES), 500+ vocabulary terms, statistical analysis (burstiness, TTR, readability). CLI and MCP server included.",
  "files": [
    "src/",
    "mcp-server/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "src/core/analyzer.js",
  "bin": {
    "humanizer": "src/cli/index.js"
  },
  "scripts": {
    "start": "node src/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'tests/**/*.js'",
    "check": "npm run lint && npm run format:check && npm test",
    "build": "echo 'No build step needed — pure Node.js'"
  },
  "keywords": [
    "ai",
    "writing",
    "humanize",
    "español",
    "spanish",
    "humanizador español",
    "llm",
    "detection",
    "text-analysis",
    "openclaw",
    "skill",
    "burstiness",
    "type-token-ratio",
    "flesch-kincaid",
    "ai-detection"
  ],
  "author": "SitoSt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SitoSt/bilingual-humanicer"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
